    def _build_steps(self, raw_steps: List[Dict]) -> List[ActionProposal]:
        steps = []
        for item in raw_steps:
            kind = str(item.get("kind", "")).strip()
            if not kind:
                continue
            target  = str(item.get("target", "")).strip()
            command = str(item.get("command", target)).strip() or target
            prop = ActionProposal(
                id=str(uuid.uuid4()), kind=kind,
                title=str(item.get("title", kind)).strip() or kind,
                target=target, command=command,
                summary=str(item.get("summary", kind)).strip() or kind,
                meta=item.get("meta") or {},
                risk=str(item.get("risk", "safe")),
            )
            if kind == "run_shell" and not prop.command:
                continue
            steps.append(prop)
        return steps

    def _review_plan(self, plan: TaskPlan) -> TaskPlan:
        reviewed = [self.policy.review(s, self.autopilot, self.shell) for s in plan.steps]
        return TaskPlan(id=plan.id, summary=plan.summary, steps=reviewed, created_at=plan.created_at)

    # ── Helpers ───────────────────────────────────────────────────────────────
    def _push(self, role: str, text: str) -> None:
        self._history.append({"role": role, "text": text, "ts": now_iso()})
        if role in ("user", "assista"):
            self.db.history_add(self._conv_id, role, text)

    def _set_status(self, status: str) -> None:
        with self._lock:
            self._status = status

    def _finalize(self, response: str, prompt: str = "") -> None:
        display = response
        try:
            parsed = json.loads(response)
            if isinstance(parsed, dict) and parsed.get("assistant_reply"):
                display = parsed["assistant_reply"].strip()
        except Exception:
            pass
        with self._lock:
            self._push("assista", display)
            self._last_response  = display
            self._streaming_text = ""
            self._busy   = False
            self._status = ""
            _auto_speak  = self.voice.auto_speak
        if prompt:
            self.memory.remember_turn(self._conv_id, prompt, display)
        if _auto_speak:
            threading.Thread(target=self.voice.speak, args=(display,), daemon=True).start()


