def now_iso() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def truncate(text: str, limit: int = 2000) -> str:
    text = text or ""
    return text if len(text) <= limit else text[:limit - 3] + "…"

def normalize_text(text: str) -> str:
    return re.sub(r"\s+", " ", (text or "").strip()).lower()

def escape_html(text: str) -> str:
    return html.escape(text or "").replace("\n", "<br>")

def render_markdown(text: str) -> str:
    safe = (text or "").replace("<script", "&lt;script")
    if markdown_lib:
        try:
            return markdown_lib.markdown(safe, extensions=["fenced_code", "tables", "nl2br"])
        except Exception:
            pass
    return escape_html(safe)

def get_active_window_title() -> str:
    try:
        if platform.system() == "Windows":
            buf = ctypes.create_unicode_buffer(512)
            hwnd = ctypes.windll.user32.GetForegroundWindow()
            ctypes.windll.user32.GetWindowTextW(hwnd, buf, 512)
            return buf.value or ""
    except Exception:
        pass
    return ""

def choose_microphone_index() -> Optional[int]:
    if sr is None:
        return None
    try:
        names = sr.Microphone.list_microphone_names()
    except Exception:
        return None
    if not names:
        return None
    preferred = ["microphone", "micro", "mic", "headset", "realtek", "input", "capture"]
    rejected  = ["stereo mix", "mixage stereo", "loopback", "output", "speaker", "haut-parleur"]
    fallback  = 0
    for idx, name in enumerate(names):
        n = normalize_text(name)
        if any(t in n for t in rejected):
            continue
        if any(t in n for t in preferred):
            return idx
        fallback = idx
    return fallback

def prepare_tts_text(text: str) -> str:
    text = (text or "").strip()
    if not text:
        return ""
    text = re.sub(r"```[\s\S]*?```", "code.", text)
    text = re.sub(r"`[^`]+`", "code", text)
    text = re.sub(r"#{1,6}\s*", "", text)
    text = re.sub(r"\*{1,2}([^*]+)\*{1,2}", r"\1", text)
    text = re.sub(r"https?://\S+", "lien web", text)
    text = re.sub(r"[_~]", "", text)
    return truncate(text.strip(), 500)

def human_size(n: int) -> str:
    for unit in ["o", "Ko", "Mo", "Go", "To"]:
        if n < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} Po"

