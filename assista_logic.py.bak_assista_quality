#  COUCHE 2 — PC MAPPER (scan complet en arrière-plan)
# ══════════════════════════════════════════════════════════════════════════════
class AssistaPCMapper:
    """
    Scanne le PC en arrière-plan et stocke la cartographie dans SQLite.
    Scan incrémental : re-scanne uniquement les chemins modifiés.
    """

    SKIP_DIRS = {
        "$Recycle.Bin", "Windows", "System32", "SysWOW64", "WinSxS",
        "node_modules", ".git", "__pycache__", ".venv", "venv",
        "AppData\\Local\\Temp", "AppData\\Local\\Microsoft\\Windows",
    }

    def __init__(self, db: AssistaDatabaseV2):
        self._db       = db
        self._running  = False
        self._thread: Optional[threading.Thread] = None
        self._progress = {
            "status":          "idle",
            "scanned":         0,
            "total_estimate":  0,
            "progress_percent":0,
            "current_path":    "",
            "current_root":    "",
            "scanned_files":   0,
            "scanned_dirs":    0,
            "running":         False,
            "message":         "En attente de scan.",
        }
        self._lock     = threading.Lock()
        self._max_files= MAX_FILES_FULL

    @property
    def progress(self) -> Dict:
        with self._lock:
            return dict(self._progress)

    def start(self, full: bool = False, quick: bool = False) -> None:
        if self._running:
            return
        self._running   = True
        self._max_files = MAX_FILES_QUICK if quick else MAX_FILES_FULL
        mode = "rapide" if quick else ("complet" if full else "standard")
        self._set_progress("scanning", 0, 0, message=f"Démarrage scan {mode}…")
        self._thread = threading.Thread(
            target=self._run, args=(full, quick), daemon=True, name="PCMapper"
        )
        self._thread.start()

    def stop(self) -> None:
        self._running = False

    def _run(self, full: bool, quick: bool = False) -> None:
        try:
            if full:
                self._db.pcmap_clear()
            if quick:
                self._scan_quick()
            else:
                self._scan_home()
                if self._running:
                    self._scan_installed_apps()
                if self._running:
                    self._scan_packages()
            count = self._db.pcmap_count()
            self._set_progress("done", count, count, message=f"Scan terminé — {count:,} entrées indexées.", percent=100)
        except Exception as e:
            self._set_progress(f"error", 0, 0, message=f"Erreur scan : {e}")
        finally:
            self._running = False

    def _scan_quick(self) -> None:
        """Scan rapide : dossiers utilisateur importants, profondeur 2, max 5 000 fichiers."""
        home = Path.home()
        quick_dirs = [
            home / "Desktop",   home / "Bureau",
            home / "Documents", home / "Downloads",
            home / "Pictures",  home / "Music",
            PROJECT_ROOT,
        ]
        batch = []
        for d in quick_dirs:
            if not d.exists() or not d.is_dir():
                continue
            self._set_progress("scanning", self._db.pcmap_count(), MAX_FILES_QUICK,
                               current_root=str(d),
                               message=f"Scan rapide : {d.name}…")
            self._walk_dir(d, batch, depth=0, max_depth=MAX_SCAN_DEPTH_QUICK)
            if not self._running:
                break
        if batch:
            self._db.pcmap_insert_many(batch)

    def _set_progress(self, status: str, scanned: int, total: int,
                      current_path: str = "", current_root: str = "",
                      message: str = "", percent: int = -1) -> None:
        pct = percent if percent >= 0 else (
            min(99, int(100 * scanned / total)) if total > 0 else 0
        )
        with self._lock:
            self._progress = {
                "status":           status,
                "scanned":          scanned,
                "total_estimate":   total,
                "progress_percent": pct,
                "current_path":     current_path,
                "current_root":     current_root,
                "scanned_files":    scanned,
                "scanned_dirs":     0,
                "running":          self._running,
                "message":          message or status,
            }

    def _scan_partitions(self) -> None:
        rows = []
        if platform.system() == "Windows":
            try:
                import ctypes as ct
                drives = []
                bitmask = ct.windll.kernel32.GetLogicalDrives()
                for letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ":
                    if bitmask & 1:
                        drives.append(letter + ":\\")
                    bitmask >>= 1
                for drive in drives:
                    try:
                        total, used, free = shutil.disk_usage(drive)
                        rows.append({
                            "path": drive, "type": "partition",
                            "size_bytes": total, "ext": "",
                            "label": f"{drive} ({human_size(free)} libre / {human_size(total)})",
                            "scanned_at": now_iso(),
                            "extra": json.dumps({"free": free, "used": used, "total": total})
                        })
                    except Exception:
                        pass
            except Exception:
                pass
        else:
            try:
                total, used, free = shutil.disk_usage("/")
                rows.append({
                    "path": "/", "type": "partition",
                    "size_bytes": total, "ext": "",
                    "label": f"/ ({human_size(free)} libre / {human_size(total)})",
                    "scanned_at": now_iso(),
                    "extra": json.dumps({"free": free, "used": used, "total": total})
                })
            except Exception:
                pass
        if rows:
            self._db.pcmap_insert_many(rows)

    def _scan_home(self) -> None:
        home    = Path.home()
        key_dirs = [
            home / "Desktop",   home / "Bureau",
            home / "Documents", home / "Downloads", home / "Téléchargements",
            home / "Pictures",  home / "Images",
            home / "Music",     home / "Musique",
            home / "Videos",    home / "Vidéos",
            home / "Projects",  home / "Dev",       home / "Code",
            PROJECT_ROOT,
        ]
        batch = []
        for d in key_dirs:
            if not d.exists() or not d.is_dir():
                continue
            self._set_progress("scanning", self._progress.get("scanned", 0),
                               self._max_files, current_root=str(d),
                               message=f"Scan : {d.name}…")
            self._walk_dir(d, batch, depth=0)
            if not self._running:
                break
        if batch:
            self._db.pcmap_insert_many(batch)

    def _walk_dir(self, path: Path, batch: List[Dict], depth: int,
                  max_depth: int = MAX_SCAN_DEPTH) -> None:
        if depth > max_depth or not self._running:
            return
        # Limite globale de fichiers
        current_count = self._progress.get("scanned", 0)
        if current_count >= self._max_files:
            self._running = False
            return
        # Skip répertoires systèmes
        for skip in self.SKIP_DIRS:
            if skip.lower() in str(path).lower():
                return
        try:
            for item in path.iterdir():
                if not self._running:
                    return
                try:
                    if item.is_dir():
                        batch.append({
                            "path": str(item), "type": "dir",
                            "size_bytes": 0, "ext": "",
                            "label": item.name, "scanned_at": now_iso(), "extra": "{}"
                        })
                        self._walk_dir(item, batch, depth + 1, max_depth)
                    elif item.is_file():
                        size = 0
                        try:
                            size = item.stat().st_size
                        except Exception:
                            pass
                        batch.append({
                            "path": str(item), "type": "file",
                            "size_bytes": size, "ext": item.suffix.lower(),
                            "label": item.name, "scanned_at": now_iso(), "extra": "{}"
                        })
                        with self._lock:
                            self._progress["scanned"] += 1
                            self._progress["scanned_files"] = self._progress["scanned"]
                            self._progress["current_path"] = str(item)
                            pct = min(99, int(100 * self._progress["scanned"] / self._max_files))
                            self._progress["progress_percent"] = pct
                            self._progress["running"] = True
                        # Pause toutes les 200 entrées pour laisser l'OS respirer
                        # et garantir que le mapper lit vraiment chaque fichier
                        if self._progress["scanned"] % 200 == 0:
                            time.sleep(0.05)
                        if self._progress["scanned"] >= self._max_files:
                            self._running = False
                            return
                    if len(batch) >= 500:
                        self._db.pcmap_insert_many(batch)
                        batch.clear()
                except Exception:
                    continue
        except PermissionError:
            pass

    def _scan_installed_apps(self) -> None:
        rows = []
        if platform.system() == "Windows":
            # Scan PATH
            for p in os.environ.get("PATH", "").split(os.pathsep):
                d = Path(p)
                if not d.exists():
                    continue
                try:
                    for f in d.glob("*.exe"):
                        rows.append({
                            "path": str(f), "type": "app",
                            "size_bytes": 0, "ext": ".exe",
                            "label": f.stem, "scanned_at": now_iso(), "extra": "{}"
                        })
                except Exception:
                    pass
        if rows:
            self._db.pcmap_insert_many(rows)

    def _scan_packages(self) -> None:
        packages = []
        # pip
        try:
            out = subprocess.run(
                [sys.executable, "-m", "pip", "list", "--format=json"],
                capture_output=True, text=True, timeout=20
            )
            if out.returncode == 0:
                for pkg in json.loads(out.stdout):
                    packages.append({"name": pkg["name"], "version": pkg["version"], "manager": "pip"})
        except Exception:
            pass
        # npm global
        try:
            out = subprocess.run(
                ["npm", "list", "-g", "--depth=0", "--json"],
                capture_output=True, text=True, timeout=20
            )
            if out.returncode == 0:
                data = json.loads(out.stdout)
                for name, info in (data.get("dependencies") or {}).items():
                    packages.append({"name": name, "version": info.get("version", ""), "manager": "npm"})
        except Exception:
            pass
        if packages:
            self._db.packages_update(packages)

