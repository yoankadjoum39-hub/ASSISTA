AssistaBrain = AssistaBrainV2


# ══════════════════════════════════════════════════════════════════════════════
#  COUCHE API BRIDGE — AssistaAPI
#  Exposée via pywebview.js_api → traduit les appels UI vers AssistaBrainV2
#  Nommage exact attendu par assista_ui.py
# ══════════════════════════════════════════════════════════════════════════════
class AssistaAPI:
    """
    Bridge entre pywebview (JS) et AssistaBrainV2 (Python).
    Toutes les méthodes sont appelées depuis assista_ui.py.
    """

    def __init__(self, brain: AssistaBrainV2) -> None:
        self._brain = brain

    # ── Initialisation ────────────────────────────────────────────────────
    def init_session(self) -> Dict:
        """Appelé au démarrage de l'UI — équivalent de bootstrap()."""
        return self._brain.bootstrap()

    # ── Chat ─────────────────────────────────────────────────────────────
    def submit_prompt(self, prompt: str) -> Dict:
        """Envoi d'un prompt utilisateur (texte ou voix)."""
        return self._brain.submit(prompt, source="text")

    def approve_plan(self, plan_id: str) -> Dict:
        return self._brain.approve_plan(plan_id)

    def reject_plan(self, plan_id: str) -> Dict:
        return self._brain.reject_plan(plan_id)

    # ── État ─────────────────────────────────────────────────────────────
    def get_state(self) -> Dict:
        """État complet pour le polling UI (toutes les 180 ms)."""
        state = self._brain.get_state()
        # Enrichit le state avec les données mapper pour refreshCtx()
        prog = self._brain.mapper.progress
        state["mapper"] = {
            "running":          prog.get("running", False),
            "progress_percent": prog.get("progress_percent", 0),
            "message":          prog.get("message", ""),
            "current_root":     prog.get("current_root", ""),
            "current_path":     prog.get("current_path", ""),
            "scanned_files":    prog.get("scanned_files", 0),
            "scanned_dirs":     prog.get("scanned_dirs", 0),
            "last_scan":        {"notes": {}, "scanned_files": prog.get("scanned_files", 0)},
        }
        # db_stats pour refreshCtx()
        try:
            db_s = self._brain.db.pcmap_stats()
            history_count = len(self._brain.db.history_get(self._brain._conv_id, 9999))
            state["db_stats"] = {
                "db_path":  str(DB_PATH),
                "messages": history_count,
                "total":    db_s.get("total", 0),
                "files":    db_s.get("files", 0),
                "dirs":     db_s.get("dirs", 0),
            }
        except Exception:
            state["db_stats"] = {}
        state["agents_count"]  = 0
        state["routines_count"]= 0
        return state

    def poll_js(self) -> List[str]:
        """Retourne les commandes JS en attente (streaming tokens)."""
        return self._brain.poll_js()

    # ── Voix ─────────────────────────────────────────────────────────────
    def start_voice(self) -> Dict:
        return self._brain.start_voice()

    def stop_voice(self) -> Dict:
        return self._brain.stop_voice()

    def set_auto_speak(self, enabled: bool) -> Dict:
        return self._brain.set_auto_speak(enabled)

    def speak_last_response(self) -> Dict:
        return self._brain.speak_last_response()

    def stop_speaking(self) -> Dict:
        return self._brain.stop_speaking()

    # ── Contrôles ─────────────────────────────────────────────────────────
    def set_autopilot(self, enabled: bool) -> Dict:
        return self._brain.set_autopilot(enabled)

    # ── Config ────────────────────────────────────────────────────────────
    def get_config(self) -> Dict:
        return self._brain.get_config()

    def save_config(self, api_key: str, model: str, base_url: str) -> Dict:
        return self._brain.save_config(api_key, model, base_url)

    # ── Mémoire ───────────────────────────────────────────────────────────
    def get_memory(self) -> Dict:
        return self._brain.get_memory()

    def forget_memory(self) -> Dict:
        return self._brain.forget_memory()

    # ── Shell log ─────────────────────────────────────────────────────────
    def get_shell_log(self, n: int = 30) -> Dict:
        return self._brain.get_shell_log(n)

    # ── PC Mapper ─────────────────────────────────────────────────────────
    def start_pc_mapper(self, full: bool = False) -> Dict:
        """Lance le scan complet du PC."""
        self._brain.mapper.start(full=full, quick=False)
        return {"ok": True, "message": "🔍 Scan PC complet lancé en arrière-plan."}

    def start_quick_scan(self) -> Dict:
        """Lance un scan rapide (dossiers importants seulement, max 5 000 fichiers)."""
        self._brain.mapper.start(full=False, quick=True)
        return {"ok": True, "message": "⚡ Scan rapide lancé (Bureau, Documents, Downloads…)"}

    def get_ops_state(self) -> Dict:
        """
        État des opérations système pour l'onglet OPS de l'UI.
        Retourne les actions récentes, sessions agents, routines.
        """
        try:
            recent = self._brain.db.get_history(self._brain._conv_id, limit=10)
            actions = [
                {"kind": m.get("role",""), "status": "OK",
                 "title": truncate(m.get("content",""), 60)}
                for m in recent[-5:]
                if m.get("role") == "assista"
            ]
        except Exception:
            actions = []
        return {
            "ok":             True,
            "security_audit": {"summary": "Aucun audit lancé.", "severity": "none"},
            "agent_sessions": [],
            "routine_runs":   [],
            "recent_actions": actions,
        }

    def run_security_audit(self) -> Dict:
        """Lance un audit de sécurité basique via shell."""
        results = []
        shell = self._brain.shell if hasattr(self._brain, "shell") else None
        if shell:
            # Vérifie les ports ouverts (Windows)
            if platform.system() == "Windows":
                r = shell.run("netstat -ano | Select-String 'LISTENING' | Select-Object -First 20 | Out-String",
                              timeout=10)
            else:
                r = shell.run("ss -tlnp 2>/dev/null | head -20", timeout=10)
            results.append(r.get("stdout", "") or r.get("stderr", ""))
        summary = f"Ports ouverts analysés. {len(results)} vérification(s)."
        msg = f"🔒 Audit terminé : {summary}"
        self._brain._push("assista", msg)
        self._brain._last_response = msg
        return {"ok": True, "message": msg,
                "security_audit": {"summary": summary, "severity": "info"}}

    # ── Analyse chemin local ───────────────────────────────────────────────
    def analyze_local_path(self, path_str: str) -> Dict:
        return self._brain.analyze_local_path(path_str)

    # ── Scan PC (alias) ───────────────────────────────────────────────────
    def scan_pc(self, full: bool = False) -> Dict:
        return self.start_pc_mapper(full=full)