#  COUCHE 1 — BASE DE DONNÉES SQLite
# ══════════════════════════════════════════════════════════════════════════════
class AssistaDatabaseV2:
    """
    Base SQLite centrale d'ASSISTA v2.
    Tables :
      - pc_map          : cartographie complète du PC (fichiers, apps, partitions)
      - preferences     : préférences utilisateur clé/valeur
      - facts           : faits mémorisés (remplace memory.json)
      - history         : historique de toutes les conversations
      - shell_audit     : journal des commandes shell
      - routines        : routines automatisées définies par l'utilisateur
      - scheduled_tasks : tâches planifiées
      - notifications   : notifications envoyées
      - packages        : packages installés (pip, npm, choco)
      - network_scans   : résultats de scans réseau
    """

    # ── Schéma ────────────────────────────────────────────────────────────────
    SCHEMA = """
    PRAGMA journal_mode=WAL;
    PRAGMA foreign_keys=ON;

    CREATE TABLE IF NOT EXISTS pc_map (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        path        TEXT NOT NULL,
        type        TEXT NOT NULL,           -- 'file' | 'dir' | 'app' | 'partition'
        size_bytes  INTEGER DEFAULT 0,
        ext         TEXT DEFAULT '',
        label       TEXT DEFAULT '',
        scanned_at  TEXT NOT NULL,
        extra       TEXT DEFAULT '{}'
    );
    CREATE INDEX IF NOT EXISTS idx_pcmap_path ON pc_map(path);
    CREATE INDEX IF NOT EXISTS idx_pcmap_ext  ON pc_map(ext);

    CREATE TABLE IF NOT EXISTS preferences (
        key         TEXT PRIMARY KEY,
        value       TEXT NOT NULL,
        updated_at  TEXT NOT NULL
    );

    CREATE TABLE IF NOT EXISTS facts (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        content     TEXT NOT NULL UNIQUE,
        source      TEXT DEFAULT 'user',
        created_at  TEXT NOT NULL
    );

    CREATE TABLE IF NOT EXISTS history (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        conv_id     TEXT NOT NULL,
        role        TEXT NOT NULL,
        content     TEXT NOT NULL,
        ts          TEXT NOT NULL,
        source      TEXT DEFAULT 'text'
    );
    CREATE INDEX IF NOT EXISTS idx_history_conv ON history(conv_id);

    CREATE TABLE IF NOT EXISTS shell_audit (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        command     TEXT NOT NULL,
        status      TEXT NOT NULL,
        detail      TEXT DEFAULT '',
        ts          TEXT NOT NULL
    );

    CREATE TABLE IF NOT EXISTS routines (
        id          TEXT PRIMARY KEY,
        label       TEXT NOT NULL,
        trigger_kw  TEXT NOT NULL,
        steps       TEXT NOT NULL,           -- JSON
        enabled     INTEGER DEFAULT 1,
        created_at  TEXT NOT NULL,
        last_used   TEXT
    );

    CREATE TABLE IF NOT EXISTS scheduled_tasks (
        id          TEXT PRIMARY KEY,
        label       TEXT NOT NULL,
        command     TEXT NOT NULL,
        kind        TEXT DEFAULT 'run_shell',
        run_at      TEXT,
        interval_s  INTEGER DEFAULT 0,
        enabled     INTEGER DEFAULT 1,
        last_run    TEXT,
        next_run    TEXT,
        created_at  TEXT NOT NULL
    );

    CREATE TABLE IF NOT EXISTS notifications (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        title       TEXT NOT NULL,
        body        TEXT NOT NULL,
        sent_at     TEXT NOT NULL,
        method      TEXT DEFAULT 'toast'
    );

    CREATE TABLE IF NOT EXISTS packages (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        name        TEXT NOT NULL,
        version     TEXT DEFAULT '',
        manager     TEXT NOT NULL,           -- pip | npm | choco | winget
        scanned_at  TEXT NOT NULL,
        UNIQUE(name, manager)
    );

    CREATE TABLE IF NOT EXISTS network_scans (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        host        TEXT NOT NULL,
        port        INTEGER,
        status      TEXT NOT NULL,
        latency_ms  REAL,
        scanned_at  TEXT NOT NULL
    );
    """

    def __init__(self, db_path: Path = DB_PATH):
        self._path = str(db_path)
        self._local = threading.local()
        self._init()

    def _conn(self) -> sqlite3.Connection:
        if not getattr(self._local, "conn", None):
            conn = sqlite3.connect(self._path, check_same_thread=False)
            conn.row_factory = sqlite3.Row
            self._local.conn = conn
        return self._local.conn

    def _init(self):
        with self._tx() as c:
            c.executescript(self.SCHEMA)

    @contextmanager
    def _tx(self):
        conn = self._conn()
        cur  = conn.cursor()
        try:
            yield cur
            conn.commit()
        except Exception:
            conn.rollback()
            raise

    # ── Preferences ───────────────────────────────────────────────────────────
    def pref_set(self, key: str, value: Any) -> None:
        with self._tx() as c:
            c.execute(
                "INSERT OR REPLACE INTO preferences(key,value,updated_at) VALUES(?,?,?)",
                (key, json.dumps(value, ensure_ascii=False), now_iso())
            )

    def pref_get(self, key: str, default: Any = None) -> Any:
        conn = self._conn()
        row  = conn.execute("SELECT value FROM preferences WHERE key=?", (key,)).fetchone()
        if row is None:
            return default
        try:
            return json.loads(row["value"])
        except Exception:
            return row["value"]

    def pref_all(self) -> Dict:
        conn = self._conn()
        rows = conn.execute("SELECT key, value FROM preferences").fetchall()
        return {r["key"]: json.loads(r["value"]) for r in rows}

    # ── Facts (mémoire persistante) ────────────────────────────────────────────
    def fact_add(self, content: str, source: str = "auto") -> None:
        content = (content or "").strip()
        if not content:
            return
        with self._tx() as c:
            c.execute(
                "INSERT OR IGNORE INTO facts(content,source,created_at) VALUES(?,?,?)",
                (content, source, now_iso())
            )
        # Purge si trop
        conn = self._conn()
        count = conn.execute("SELECT COUNT(*) FROM facts").fetchone()[0]
        if count > MAX_MEMORY_FACTS:
            with self._tx() as c:
                c.execute(
                    "DELETE FROM facts WHERE id IN "
                    "(SELECT id FROM facts ORDER BY id ASC LIMIT ?)",
                    (count - MAX_MEMORY_FACTS,)
                )

    def fact_list(self, n: int = 50) -> List[str]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT content FROM facts ORDER BY id DESC LIMIT ?", (n,)
        ).fetchall()
        return [r["content"] for r in rows]

    def fact_clear(self) -> None:
        with self._tx() as c:
            c.execute("DELETE FROM facts")

    # ── History ───────────────────────────────────────────────────────────────
    def history_add(self, conv_id: str, role: str, content: str, source: str = "text") -> None:
        with self._tx() as c:
            c.execute(
                "INSERT INTO history(conv_id,role,content,ts,source) VALUES(?,?,?,?,?)",
                (conv_id, role, content, now_iso(), source)
            )

    def history_get(self, conv_id: str, n: int = 40) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT role,content,ts,source FROM history "
            "WHERE conv_id=? ORDER BY id DESC LIMIT ?",
            (conv_id, n)
        ).fetchall()
        return [dict(r) for r in reversed(rows)]

    def history_convs(self) -> List[str]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT DISTINCT conv_id FROM history ORDER BY id DESC"
        ).fetchall()
        return [r["conv_id"] for r in rows]

    # ── Shell audit ───────────────────────────────────────────────────────────
    def audit_add(self, command: str, status: str, detail: str = "") -> None:
        with self._tx() as c:
            c.execute(
                "INSERT INTO shell_audit(command,status,detail,ts) VALUES(?,?,?,?)",
                (truncate(command, 500), status, detail, now_iso())
            )

    def audit_get(self, n: int = 50) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT command,status,detail,ts FROM shell_audit ORDER BY id DESC LIMIT ?",
            (n,)
        ).fetchall()
        return [dict(r) for r in rows]

    # ── PC Map ────────────────────────────────────────────────────────────────
    def pcmap_clear(self) -> None:
        with self._tx() as c:
            c.execute("DELETE FROM pc_map")

    def pcmap_insert_many(self, rows: List[Dict]) -> None:
        with self._tx() as c:
            c.executemany(
                "INSERT OR REPLACE INTO pc_map(path,type,size_bytes,ext,label,scanned_at,extra) "
                "VALUES(:path,:type,:size_bytes,:ext,:label,:scanned_at,:extra)",
                rows
            )

    def pcmap_search(self, query: str, limit: int = 30) -> List[Dict]:
        conn = self._conn()
        q    = f"%{query.lower()}%"
        rows = conn.execute(
            "SELECT path,type,size_bytes,ext,label FROM pc_map "
            "WHERE lower(path) LIKE ? OR lower(label) LIKE ? LIMIT ?",
            (q, q, limit)
        ).fetchall()
        return [dict(r) for r in rows]

    def pcmap_count(self) -> int:
        return self._conn().execute("SELECT COUNT(*) FROM pc_map").fetchone()[0]

    def pcmap_stats(self) -> Dict:
        conn = self._conn()
        total     = conn.execute("SELECT COUNT(*) FROM pc_map").fetchone()[0]
        files     = conn.execute("SELECT COUNT(*) FROM pc_map WHERE type='file'").fetchone()[0]
        dirs      = conn.execute("SELECT COUNT(*) FROM pc_map WHERE type='dir'").fetchone()[0]
        top_exts  = conn.execute(
            "SELECT ext, COUNT(*) cnt FROM pc_map WHERE type='file' AND ext!='' "
            "GROUP BY ext ORDER BY cnt DESC LIMIT 10"
        ).fetchall()
        return {
            "total": total, "files": files, "dirs": dirs,
            "top_extensions": [dict(r) for r in top_exts],
        }

    # ── Routines ──────────────────────────────────────────────────────────────
    def routine_add(self, label: str, trigger_kw: str, steps: List[Dict]) -> str:
        rid = str(uuid.uuid4())
        with self._tx() as c:
            c.execute(
                "INSERT INTO routines(id,label,trigger_kw,steps,enabled,created_at) "
                "VALUES(?,?,?,?,1,?)",
                (rid, label, trigger_kw, json.dumps(steps, ensure_ascii=False), now_iso())
            )
        return rid

    def routine_list(self) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT id,label,trigger_kw,steps,enabled,created_at,last_used "
            "FROM routines WHERE enabled=1"
        ).fetchall()
        result = []
        for r in rows:
            d = dict(r)
            d["steps"] = json.loads(d["steps"])
            result.append(d)
        return result

    def routine_match(self, prompt: str) -> Optional[Dict]:
        lower = normalize_text(prompt)
        for r in self.routine_list():
            if normalize_text(r["trigger_kw"]) in lower:
                return r
        return None

    def routine_delete(self, rid: str) -> None:
        with self._tx() as c:
            c.execute("DELETE FROM routines WHERE id=?", (rid,))

    # ── Scheduled tasks ───────────────────────────────────────────────────────
    def task_add(self, task: ScheduledTask) -> None:
        with self._tx() as c:
            c.execute(
                "INSERT OR REPLACE INTO scheduled_tasks "
                "(id,label,command,kind,run_at,interval_s,enabled,last_run,next_run,created_at) "
                "VALUES(?,?,?,?,?,?,?,?,?,?)",
                (task.id, task.label, task.command, task.kind,
                 task.run_at, task.interval_s, int(task.enabled),
                 task.last_run, task.next_run, now_iso())
            )

    def task_list(self) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT * FROM scheduled_tasks WHERE enabled=1 ORDER BY next_run"
        ).fetchall()
        return [dict(r) for r in rows]

    def task_delete(self, tid: str) -> None:
        with self._tx() as c:
            c.execute("DELETE FROM scheduled_tasks WHERE id=?", (tid,))

    def task_update_run(self, tid: str, last_run: str, next_run: Optional[str]) -> None:
        with self._tx() as c:
            c.execute(
                "UPDATE scheduled_tasks SET last_run=?, next_run=? WHERE id=?",
                (last_run, next_run, tid)
            )

    # ── Notifications ─────────────────────────────────────────────────────────
    def notif_add(self, title: str, body: str, method: str = "toast") -> None:
        with self._tx() as c:
            c.execute(
                "INSERT INTO notifications(title,body,sent_at,method) VALUES(?,?,?,?)",
                (title, body, now_iso(), method)
            )

    def notif_list(self, n: int = 20) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT title,body,sent_at,method FROM notifications ORDER BY id DESC LIMIT ?",
            (n,)
        ).fetchall()
        return [dict(r) for r in rows]

    # ── Packages ──────────────────────────────────────────────────────────────
    def packages_update(self, packages: List[Dict]) -> None:
        ts = now_iso()
        with self._tx() as c:
            for pkg in packages:
                c.execute(
                    "INSERT OR REPLACE INTO packages(name,version,manager,scanned_at) "
                    "VALUES(?,?,?,?)",
                    (pkg["name"], pkg.get("version", ""), pkg["manager"], ts)
                )

    def packages_list(self, manager: Optional[str] = None) -> List[Dict]:
        conn = self._conn()
        if manager:
            rows = conn.execute(
                "SELECT name,version,manager,scanned_at FROM packages WHERE manager=? "
                "ORDER BY name", (manager,)
            ).fetchall()
        else:
            rows = conn.execute(
                "SELECT name,version,manager,scanned_at FROM packages ORDER BY manager,name"
            ).fetchall()
        return [dict(r) for r in rows]

    # ── Network scans ─────────────────────────────────────────────────────────
    def netscan_add(self, host: str, port: Optional[int], status: str,
                    latency_ms: Optional[float] = None) -> None:
        with self._tx() as c:
            c.execute(
                "INSERT INTO network_scans(host,port,status,latency_ms,scanned_at) "
                "VALUES(?,?,?,?,?)",
                (host, port, status, latency_ms, now_iso())
            )

    def netscan_recent(self, n: int = 20) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(
            "SELECT host,port,status,latency_ms,scanned_at FROM network_scans "
            "ORDER BY id DESC LIMIT ?", (n,)
        ).fetchall()
        return [dict(r) for r in rows]

    # ── Raw query (agent DB) ───────────────────────────────────────────────────
    def raw_query(self, sql: str, params: tuple = ()) -> List[Dict]:
        conn = self._conn()
        rows = conn.execute(sql, params).fetchall()
        return [dict(r) for r in rows]

