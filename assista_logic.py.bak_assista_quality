    # ── Analyse chemin ────────────────────────────────────────────────────────
    def analyze_local_path(self, path_str: str) -> Dict:
        path = Path(path_str.strip().strip('"\''))
        if not path.exists():
            return {"ok": False, "error": f"Introuvable : {path}",
                    "message": f"❌ Chemin introuvable : `{path}`"}
        if path.is_file():
            result = self.registry.execute(ActionProposal(
                id=str(uuid.uuid4()), kind="read_file",
                title=f"Lire {path.name}", target=str(path)
            ))
            msg = result.get("message", "")
            self.memory.add_fact(f"Fichier analysé : {path} ({path.stat().st_size} o)")
            with self._lock:
                self._push("assista", f"📄 Analyse de `{path.name}` :\n\n{truncate(msg, 3000)}")
                self._last_response = msg
            return {"ok": True, "message": msg, "path": str(path), "type": "file"}
        if path.is_dir():
            files_found = []
            try:
                for item in sorted(path.rglob("*"))[:200]:
                    if item.is_file():
                        files_found.append(str(item.relative_to(path)))
            except Exception as e:
                return {"ok": False, "error": str(e), "message": f"❌ {e}"}
            lines = [f"📁 **Dossier :** `{path}`",
                     f"📊 **{len(files_found)} fichiers**", "", "**Contenu :**"]
            for f in files_found[:40]:
                lines.append(f"  • `{f}`")
            if len(files_found) > 40:
                lines.append(f"  … et {len(files_found)-40} autres")
            msg = "\n".join(lines)
            self.memory.add_fact(f"Projet analysé : {path} ({len(files_found)} fichiers)")
            with self._lock:
                self._push("assista", msg); self._last_response = msg
            return {"ok": True, "message": msg, "path": str(path), "type": "dir", "files": files_found[:40]}
        return {"ok": False, "error": "Type inconnu", "message": f"❌ Type inconnu : {path}"}

    # ── État complet ──────────────────────────────────────────────────────────
    def get_state(self) -> Dict:
        return self._state()

    def _state(self, message: str = "") -> Dict:
        with self._lock:
            voice = self.voice.get_state()
            self.voice.refresh_idle()
            plan_data = None
            if self._pending_plan:
                plan_data = {
                    "id":      self._pending_plan.id,
                    "summary": self._pending_plan.summary,
                    "steps": [
                        {"title": s.title, "kind": s.kind, "target": s.target,
                         "command": s.command, "risk": s.risk, "summary": s.summary}
                        for s in self._pending_plan.steps
                    ],
                }
            return {
                "message":           message,
                "status":            self._status,
                "response":          self._last_response,
                "streaming_text":    self._streaming_text,
                "busy":              self._busy,
                "autopilot":         self.autopilot,
                "auto_speak":        self.voice.auto_speak,
                "plan":              plan_data,
                "plan_id":           self._pending_plan.id if self._pending_plan else None,
                "voice_status":      voice["status"],
                "voice_listening":   voice["listening"],
                "voice_speaking":    voice["speaking"],
                "voice_awake":       voice["awake"],
                "voice_volume":      voice["volume"],
                "voice_confirm":     self._voice_confirm,
                "voice_confirm_msg": self._voice_confirm_prompt,
                "history":           self._history[-40:],
                "memory_facts_count": len(self.memory.get_facts(9999)),
                "pcmap_count":       self.db.pcmap_count(),
                "mapper_status":     self.mapper.progress["status"],
                "version":           "2.0",
            }

    # ══════════════════════════════════════════════════════════════════════════
    #  WORKER
    # ══════════════════════════════════════════════════════════════════════════
    def _worker(self, prompt: str, source: str) -> None:
        try:
            # [1] Routines automatisées (DB)
            routine = self.db.routine_match(prompt)
            if routine:
                self._set_status(f"Routine : {routine['label']}")
                steps = [
                    ActionProposal(
                        id=str(uuid.uuid4()), kind=s.get("kind", "run_shell"),
                        title=s.get("title", ""), target=s.get("target", ""),
                        command=s.get("command", ""), summary=s.get("summary", ""),
                        meta=s.get("meta", {})
                    )
                    for s in routine["steps"]
                ]
                plan = TaskPlan(id=str(uuid.uuid4()), summary=routine["label"], steps=steps)
                reviewed = self._review_plan(plan)
                needs_confirm = any(s.requires_confirm for s in reviewed.steps)
                if needs_confirm:
                    self._ask_confirmation(reviewed, source)
                    return
                self._execute_plan_bg(reviewed, f"▶️ Routine : {routine['label']}")
                return

            # [2] Commandes prédéfinies
            if _COMMANDS_AVAILABLE:
                self._set_status("Recherche commande…")
                matched = try_command_match(prompt)
                if matched:
                    proposal = ActionProposal(
                        id=str(uuid.uuid4()), kind=matched["kind"],
                        title=matched["title"], target=matched.get("target", ""),
                        command=matched.get("command", ""), summary=matched.get("summary", ""),
                        meta=matched.get("meta", {}),
                    )
                    reviewed = self.policy.review(proposal, self.autopilot, self.shell)
                    if reviewed.requires_confirm:
                        self._ask_confirmation(
                            TaskPlan(id=str(uuid.uuid4()), summary=reviewed.title, steps=[reviewed]),
                            source,
                        )
                        return
                    result = self.registry.execute(reviewed)
                    reply  = result.get("message", reviewed.summary)
                    self._finalize(reply, prompt)
                    if self.voice.auto_speak or source == "voice":
                        self.voice.speak(reviewed.summary)
                    return

            # [3] LLM - planification JSON
            self._set_status("Planification LLM...")
            payload = self._plan_with_llm(prompt)
            mode    = payload.get("mode", "chat")
            steps   = self._build_steps(payload.get("steps") or [])

            if mode == "action" and steps:
                plan     = TaskPlan(id=str(uuid.uuid4()),
                                    summary=payload.get("assistant_reply", "Plan"), steps=steps)
                reviewed = self._review_plan(plan)
                needs_confirm = any(s.requires_confirm or s.requires_approval for s in reviewed.steps)
                if needs_confirm:
                    self._ask_confirmation(reviewed, source)
                    return
                self._execute_plan_bg(reviewed, payload.get("assistant_reply", reviewed.summary))
                return

            # [4] Chat direct
            reply = payload.get("assistant_reply", "").strip()
            if not reply:
                self._set_status("Génération réponse…")
                reply = self._stream_response(prompt)
            self._finalize(reply, prompt)
            if self.voice.auto_speak or source == "voice":
                self.voice.speak(reply)

        except Exception as exc:
            with self._lock:
                msg = f"⚠️ Erreur ASSISTA v2 : {exc}"
                self._push("assista", msg)
                self._last_response = msg
                self._busy  = False
                self._status = ""

    def _ask_confirmation(self, plan: TaskPlan, source: str) -> None:
        summary = "\n".join(f"• [{s.risk.upper()}] {s.title}" for s in plan.steps)
        msg = (
            f"**Plan nécessitant votre validation :**\n\n{summary}\n\n"
            "Approuvez ou annulez via les boutons, ou répondez « oui » / « non »."
        )
        with self._lock:
            self._pending_plan           = plan
            self._voice_confirm          = source == "voice"
            self._voice_confirm_prompt   = f"Je vais exécuter : {plan.summary}. Confirmez-vous ?"
            self._push("assista", msg)
            self._last_response = msg
            self._busy   = False
            self._status = "En attente de validation."
        if source == "voice":
            self.voice.speak(self._voice_confirm_prompt)

    def _execute_plan_bg(self, plan: TaskPlan, prefix: str) -> None:
        try:
            self._set_status("Exécution du plan…")
            parts = [prefix] if prefix else []
            for i, step in enumerate(plan.steps, 1):
                self._set_status(f"Étape {i}/{len(plan.steps)} : {step.title}…")
                self._queue_js(f"assistaSetStatus({json.dumps(f'⚙️ {i}/{len(plan.steps)} — {step.title}')})")
                result = self.registry.execute(step)
                if result.get("_speak"):
                    self.voice.speak(result["_speak"])
                msg = result.get("message", "")
                parts.append(f"**Étape {i} — {step.title}**\n{msg}")
                self._queue_js(f"assistaStepDone({json.dumps(step.title)}, {json.dumps('ok' if result.get('ok') else 'error')})")
            reply = "\n\n".join(filter(None, parts))
            self._finalize(reply, plan.summary)
        except Exception as exc:
            with self._lock:
                msg = f"⚠️ Erreur exécution plan : {exc}"
                self._push("assista", msg)
                self._last_response = msg
                self._busy  = False
                self._status = ""

    # ── LLM ───────────────────────────────────────────────────────────────────
    def _plan_with_llm(self, prompt: str) -> Dict:
        facts  = self.memory.get_facts(30)
        recent = self.memory.get_recent_turns(self._conv_id, 6)
        ctx    = self.context.snapshot()
        stats  = self.db.pcmap_stats()
        history = [
            {"role": "user" if m["role"] == "user" else "assistant", "content": m["text"]}
            for m in self._history[-MAX_HISTORY_TURNS * 2:]
            if m["role"] in ("user", "assista")
        ]
        user_payload = {
            "prompt":  prompt,
            "history": history,
            "memory":  {"facts": facts, "recent_turns": recent},
            "context": ctx,
            "db_stats": stats,
            "tools":   self._tools_schema(),
        }
        payload = self.llm.complete_json([
            {"role": "system", "content": SYSTEM_PROMPT_V2},
            {"role": "user",   "content": json.dumps(user_payload, ensure_ascii=False)},
        ])
        for fact in payload.get("remember", []) or []:
            self.memory.add_fact(str(fact))
        return payload

    def _stream_response(self, prompt: str) -> str:
        history = [
            {"role": "user" if m["role"] == "user" else "assistant", "content": m["text"]}
            for m in self._history[-MAX_HISTORY_TURNS * 2:]
            if m["role"] in ("user", "assista")
        ]
        msgs   = [{"role": "system", "content": SYSTEM_PROMPT_V2}] + history
        tokens = []
        self._queue_js("assistaStreamStart()")
        def on_token(t):
            tokens.append(t)
            with self._lock:
                self._streaming_text = "".join(tokens)
            self._queue_js(f"assistaStreamToken({json.dumps(t)})")
        result = self.llm.stream_chat(msgs, on_token=on_token)
        self._queue_js("assistaStreamEnd()")
        return result

