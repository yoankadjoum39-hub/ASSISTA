#  COUCHE 4 — LLM
# ══════════════════════════════════════════════════════════════════════════════
class AssistaLLM:
    try:
        from nexus_core.aria_engine import answer_question as _aria_answer
        _USE_ARIA_ENGINE = True
    except Exception:
        _aria_answer      = None
        _USE_ARIA_ENGINE  = False

    def __init__(self, config: AssistaConfig) -> None:
        self._config = config

    def _headers_and_url(self, stream: bool) -> Tuple[Dict, str, str]:
        cfg     = self._config.load()
        api_key = (cfg.get("api_key", "") or "").strip() \
                  or os.getenv("OPENROUTER_API_KEY", "").strip()
        if not api_key:
            raise RuntimeError(
                "Aucune clé API configurée. "
                "Ouvrez ⚙ Config dans ASSISTA et entrez votre clé OpenRouter, "
                "ou définissez la variable d'environnement OPENROUTER_API_KEY."
            )
        model    = (cfg.get("model", DEFAULT_MODEL) or DEFAULT_MODEL).strip()
        # Mode auto : on commence par le premier modèle de la liste
        if not model or model == "__auto__":
            model = FALLBACK_MODELS[0]
        base_url = (cfg.get("base_url", DEFAULT_BASE_URL) or DEFAULT_BASE_URL).strip()
        headers  = {
            "Authorization": f"Bearer {api_key}",
            "Content-Type":  "application/json",
            "HTTP-Referer":  "http://localhost",
            "X-Title":       "ASSISTA v2",
        }
        if stream:
            headers["Accept"] = "text/event-stream"
        return headers, base_url, model

    def _sse_stream(self, messages: List[Dict], on_token: Optional[Callable] = None) -> str:
        headers, base_url, first_model = self._headers_and_url(stream=True)
        cfg         = self._config.load()
        saved_model = (cfg.get("model", DEFAULT_MODEL) or DEFAULT_MODEL).strip()
        # Mode auto → rotation complète ; mode manuel → un seul modèle, pas de fallback
        if saved_model in ("__auto__", "", DEFAULT_MODEL):
            models_to_try = FALLBACK_MODELS
        else:
            models_to_try = [saved_model]
        last_error = None
        for mdl in models_to_try:
            body   = json.dumps({"model": mdl, "stream": True, "messages": messages}).encode()
            parsed = urllib.parse.urlparse(base_url)
            conn   = http.client.HTTPSConnection(
                parsed.netloc, context=ssl.create_default_context(), timeout=60
            )
            try:
                conn.request("POST", parsed.path, body=body, headers=headers)
                resp = conn.getresponse()
            except Exception as e:
                conn.close(); last_error = str(e); continue
            if resp.status in (429, 404, 410):
                resp.read(); conn.close()
                last_error = f"HTTP {resp.status} sur {mdl}"; continue
            if resp.status != 200:
                resp.read(); conn.close()
                last_error = f"HTTP {resp.status} sur {mdl}"; continue
            chunks: List[str] = []
            buf = b""
            try:
                while True:
                    packet = resp.read(512)
                    if not packet:
                        break
                    buf += packet
                    while b"\n" in buf:
                        line_b, buf = buf.split(b"\n", 1)
                        line = line_b.decode("utf-8", errors="replace").strip()
                        if not line.startswith("data:"):
                            continue
                        data = line[5:].strip()
                        if data == "[DONE]":
                            break
                        try:
                            token = (
                                json.loads(data).get("choices", [{}])[0]
                                .get("delta", {}).get("content", "")
                            )
                            if token:
                                chunks.append(token)
                                if on_token:
                                    on_token(token)
                        except json.JSONDecodeError:
                            continue
            finally:
                conn.close()
            result = "".join(chunks).strip()
            if result:
                return result
            last_error = f"Réponse vide de {mdl}"
        raise RuntimeError(f"Tous les modèles ont échoué : {last_error}")

    def stream_chat(self, messages: List[Dict], on_token: Optional[Callable] = None) -> str:
        if self.__class__._USE_ARIA_ENGINE and self.__class__._aria_answer is not None:
            system_content = ""
            history: List[Dict] = []
            prompt = ""
            for msg in messages:
                role = msg.get("role", "")
                content = msg.get("content", "")
                if role == "system":
                    system_content = content
                elif role == "user":
                    history.append({"role": "user", "content": content})
                    prompt = content
                elif role == "assistant":
                    history.append({"role": "assistant", "content": content})
            if history and history[-1]["role"] == "user":
                history = history[:-1]
            full_prompt = (
                f"[INSTRUCTIONS SYSTÈME — PRIORITÉ ABSOLUE]\n{system_content}\n\n"
                f"[DEMANDE UTILISATEUR]\n{prompt}"
            ) if system_content else prompt
            chunks: List[str] = []
            def collect(t):
                chunks.append(t)
                if on_token:
                    on_token(t)
            try:
                result = self.__class__._aria_answer(
                    full_prompt, "admin",
                    stream_callback=collect, history=history, theme="",
                )
                text = result[0] if isinstance(result, tuple) else str(result)
                return "".join(chunks).strip() or text.strip()
            except Exception as e:
                print(f"[AssistaLLM] aria_engine échoué ({e}), fallback SSE")
                return self._sse_stream(messages, on_token=on_token)
        return self._sse_stream(messages, on_token=on_token)

    def complete_json(self, messages: List[Dict]) -> Dict:
        chunks: List[str] = []
        def collect(t): chunks.append(t)
        cfg = self._config.load()
        api_key = (cfg.get("api_key", "") or "").strip() or os.getenv("OPENROUTER_API_KEY", "").strip()
        if not api_key:
            return self._local_planner(messages, RuntimeError("Aucune cle API configuree."))
        try:
            result = self.stream_chat(messages, on_token=collect)
            return self._extract_json(result)
        except Exception as e:
            return self._local_planner(messages, e)

    def _local_planner(self, messages: List[Dict], error: Exception = None) -> Dict:
        """Secours sans API: garde ASSISTA utilisable pour chat et actions PC courantes."""
        prompt = ""
        for msg in reversed(messages):
            if msg.get("role") == "user":
                content = msg.get("content", "")
                try:
                    data = json.loads(content)
                    prompt = data.get("prompt", content)
                except Exception:
                    prompt = content
                break
        raw = (prompt or "").strip()
        low = normalize_text(raw)

        def chat(reply: str) -> Dict:
            if error:
                reply += "\n\n_Mode local actif : la connexion/API n'est pas disponible, donc je reponds avec mes outils integres._"
            return {"mode": "chat", "assistant_reply": reply, "agent": "AgentLocal", "remember": [], "steps": []}

        if not raw:
            return chat("Je n'ai pas recu de demande exploitable.")
        if any(x in low for x in ["bonjour", "salut", "hello", "coucou"]):
            return chat("Bonjour ! Je suis prete. Je peux discuter, ouvrir des applications, lire le PC, chercher des fichiers, donner l'etat systeme/reseau et apprendre des exemples via ASSISTA_MODEL.")
        if any(x in low for x in ["que sais", "tu peux", "capacite", "fonction"]):
            return chat("Je peux agir avec mes agents fichiers, systeme, reseau, developpement, clipboard, notifications, planification, securite et cartographie PC. Pour les actions sensibles, je demande validation.")

        app_map = {
            "bloc note": "notepad", "bloc-notes": "notepad", "notepad": "notepad",
            "calculatrice": "calculator", "calc": "calculator", "chrome": "chrome",
            "edge": "edge", "explorer": "explorer", "fichiers": "explorer",
            "vscode": "vscode", "vs code": "vscode",
        }
        if low.startswith("ouvre ") or low.startswith("lance "):
            for name, target in app_map.items():
                if name in low:
                    return {"mode": "action", "assistant_reply": f"Je vais ouvrir {name}.", "agent": "AgentSysteme", "remember": [], "steps": [{"kind": "open_app", "title": f"Ouvrir {name}", "target": target, "summary": f"Lancement de {name}", "risk": "safe", "meta": {}}]}
        if "ip" in low or "reseau" in low or "réseau" in low:
            return {"mode": "action", "assistant_reply": "Je vais lire les informations reseau locales.", "agent": "AgentReseau", "remember": [], "steps": [{"kind": "network_info", "title": "Informations reseau", "summary": "Adresse IP et interfaces", "risk": "safe", "meta": {}}]}
        if "capture" in low and ("ecran" in low or "écran" in low):
            return {"mode": "action", "assistant_reply": "Je vais prendre une capture d'ecran.", "agent": "AgentSysteme", "remember": [], "steps": [{"kind": "capture_screen", "title": "Capture d'ecran", "summary": "Capture du bureau", "risk": "safe", "meta": {}}]}
        if "stat" in low and ("db" in low or "base" in low or "assista" in low):
            return {"mode": "action", "assistant_reply": "Je vais afficher les statistiques ASSISTA.", "agent": "AgentSecurite", "remember": [], "steps": [{"kind": "db_stats", "title": "Statistiques ASSISTA", "summary": "Etat de la base ASSISTA", "risk": "safe", "meta": {}}]}
        if "process" in low or "processus" in low:
            return {"mode": "action", "assistant_reply": "Je vais lister les processus actifs.", "agent": "AgentSysteme", "remember": [], "steps": [{"kind": "list_processes", "title": "Lister les processus", "summary": "Processus actifs", "risk": "safe", "meta": {}}]}

        return chat("Je suis en mode local et je peux deja traiter les demandes courantes. Pour les demandes complexes en langage naturel, ajoutez une cle OpenRouter dans Config afin d'activer la planification LLM complete.")

    def _extract_json(self, text: str) -> Dict:
        cleaned = text
        if "```" in cleaned:
            m = re.search(r"```(?:json)?\s*([\s\S]+?)```", cleaned)
            if m:
                cleaned = m.group(1).strip()
        brace = cleaned.find("{")
        if brace != -1:
            cleaned = cleaned[brace:]
            depth = 0
            for i, ch in enumerate(cleaned):
                if ch == "{": depth += 1
                elif ch == "}":
                    depth -= 1
                    if depth == 0:
                        cleaned = cleaned[:i + 1]; break
        try:
            return json.loads(cleaned)
        except json.JSONDecodeError:
            try:
                return json.loads(text)
            except json.JSONDecodeError as e:
                raise RuntimeError(f"JSON LLM invalide : {e} | extrait={truncate(text, 300)}")

