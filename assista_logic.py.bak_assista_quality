#  COUCHE 5 — SHELL EXECUTOR
# ══════════════════════════════════════════════════════════════════════════════
class AssistaShell:
    BLACKLIST = [
        r"\brm\s+-rf\s+/",
        r"\bformat\s+[a-zA-Z]:",
        r"\bdel\s+/[fqs].*\\\*",
        r"Remove-Item.*-Recurse.*-Force.*[Cc]:\\",
        r":\(\)\{\s*:\|:&\s*\};:",
        r"\bshutdown\b.*(/s|--poweroff)",
        r"\brd\s+/s\s+/q\s+[a-zA-Z]:",
        r"Invoke-Expression.*\(New-Object.*DownloadString",
        r"powershell.*-enc\s+[A-Za-z0-9+/=]{40,}",
    ]
    SENSITIVE_KEYWORDS = [
        "delete", "remove", "erase", "format", "drop",
        "rm ", "del ", "rmdir", "rd ", "mv ", "move ",
        "shutdown", "restart", "reboot", "halt",
        "net user", "net localgroup", "reg delete",
        "cipher", "bcdedit", "diskpart",
    ]

    def __init__(self, db: AssistaDatabaseV2) -> None:
        self._is_windows = platform.system() == "Windows"
        self._db         = db

    def classify(self, command: str) -> Dict:
        cmd_lower = command.lower().strip()
        for pattern in self.BLACKLIST:
            if re.search(pattern, command, re.IGNORECASE):
                return {"allowed": False, "risk": "blocked",
                        "reason": f"Commande refusée (blacklist) : {pattern}"}
        for kw in self.SENSITIVE_KEYWORDS:
            if kw in cmd_lower:
                return {"allowed": True, "risk": "dangerous",
                        "reason": f"Commande sensible : '{kw}'"}
        write_patterns = [
            r"\bNew-Item\b", r"\bSet-Content\b", r"\bOut-File\b",
            r"\bcopy\b", r"\bxcopy\b", r"\brobocopy\b",
            r"\bmkdir\b", r"\bmd\b", r"\btouch\b", r"\bcp\b",
            r"\bwrite\b", r"\becho.*>", r"\bpip\s+install\b",
            r"\bnpm\s+install\b", r"\bgit\b",
        ]
        for p in write_patterns:
            if re.search(p, command, re.IGNORECASE):
                return {"allowed": True, "risk": "moderate",
                        "reason": "Commande d'écriture ou d'installation"}
        return {"allowed": True, "risk": "safe", "reason": "Commande de lecture/observation"}

    def run(self, command: str, timeout: int = MAX_SHELL_TIMEOUT, cwd: Optional[str] = None) -> Dict:
        check = self.classify(command)
        if not check["allowed"]:
            self._db.audit_add(command, "BLOCKED", check["reason"])
            return {"ok": False, "stdout": "", "stderr": check["reason"],
                    "returncode": -1, "message": f"🚫 {check['reason']}"}
        shell_cmd = (
            ["powershell.exe", "-NonInteractive", "-Command", command]
            if self._is_windows else ["bash", "-c", command]
        )
        kwargs = dict(
            capture_output=True, text=True, timeout=timeout,
            cwd=cwd, encoding="utf-8", errors="replace"
        )
        if self._is_windows:
            kwargs["creationflags"] = 0x08000000
        try:
            result = subprocess.run(shell_cmd, **kwargs)
            stdout = truncate(result.stdout or "", MAX_FILE_CHARS)
            stderr = truncate(result.stderr or "", 2000)
            ok     = result.returncode == 0
            self._db.audit_add(command, "OK" if ok else "ERROR", f"rc={result.returncode}")
            output = stdout or stderr or "Commande exécutée sans sortie."
            return {
                "ok": ok, "stdout": stdout, "stderr": stderr,
                "returncode": result.returncode,
                "message": (f"✅ Exécuté\n```\n{output}\n```" if ok
                            else f"⚠️ Erreur (code {result.returncode})\n```\n{output}\n```"),
            }
        except subprocess.TimeoutExpired:
            self._db.audit_add(command, "TIMEOUT", f">{timeout}s")
            return {"ok": False, "stdout": "", "stderr": f"Timeout ({timeout}s)",
                    "returncode": -2, "message": f"⚠️ Timeout ({timeout}s)."}
        except Exception as exc:
            self._db.audit_add(command, "EXCEPTION", str(exc))
            return {"ok": False, "stdout": "", "stderr": str(exc),
                    "returncode": -3, "message": f"⚠️ Erreur : {exc}"}

