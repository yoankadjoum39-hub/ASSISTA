#  COUCHE 7 — VOIX
# ══════════════════════════════════════════════════════════════════════════════
WAKE_WORDS  = {"salut", "bonjour", "hey assista", "assista", "réveille-toi", "reveille-toi"}
SLEEP_WORDS = {"au revoir", "bonne nuit", "dors", "en veille", "stop assista"}

class AssistaVoice:
    """
    Gestion TTS (pyttsx3) + STT (SpeechRecognition).

    BUG CORRIGÉ — Relance TTS impossible :
    pyttsx3 est mono-thread par design. Appeler engine.stop() puis engine.runAndWait()
    dans un thread différent corrompt le moteur COM → il ne peut plus redémarrer.
    Solution : on crée un moteur neuf à chaque appel speak(), dans son propre thread,
    et on l'arrête via un Event threading plutôt que engine.stop().
    """

    def __init__(self, brain: "AssistaBrainV2") -> None:
        self._brain        = brain
        self._stop_fn      = None          # STT background listener
        self._listening    = False
        self._speaking     = False
        self._awake        = False
        self.auto_speak    = False
        self.status        = "Voix non initialisée"
        self._volume       = 0.0
        self._lock         = threading.Lock()
        # Contrôle du thread TTS actif
        self._tts_stop_evt = threading.Event()
        self._tts_thread:  Optional[threading.Thread] = None

    # ── TTS ───────────────────────────────────────────────────────────────
    def speak(self, text: str) -> Dict:
        """Lance la lecture TTS dans un thread dédié avec moteur neuf."""
        clean = prepare_tts_text(text)
        if not clean:
            return {"ok": True, "message": "Rien à prononcer."}
        if pyttsx3 is None:
            return {"ok": False, "message": "TTS indisponible (pip install pyttsx3)."}

        # Stoppe toute lecture en cours avant de relire un autre message.
        self._request_stop_tts(wait=1.2)

        self._tts_stop_evt = threading.Event()
        stop_evt = self._tts_stop_evt

        def _run():
            engine = None
            try:
                # Nouveau moteur à chaque fois → jamais de corruption COM
                engine = pyttsx3.init()
                engine.setProperty("rate", 175)
                engine.setProperty("volume", 0.9)
            except Exception as e:
                with self._lock:
                    self._speaking = False
                    self.status    = "Prête"
                return

            with self._lock:
                self._speaking = True
                self.status    = "ASSISTA parle…"

            try:
                engine.say(clean)
                # runAndWait en boucle courte pour répondre au stop_evt
                engine.startLoop(False)
                while not stop_evt.is_set():
                    try:
                        engine.iterate()
                    except Exception:
                        break
                    # Vérifie si le moteur a fini naturellement
                    if not engine.isBusy():
                        break
                engine.endLoop()
            except AttributeError:
                # Fallback : ancienne API pyttsx3 sans startLoop/iterate
                if not stop_evt.is_set():
                    try:
                        engine.runAndWait()
                    except Exception:
                        pass
            except Exception:
                pass
            finally:
                # Nettoyage moteur dans son propre thread (obligatoire)
                try:
                    engine.stop()
                except Exception:
                    pass
                with self._lock:
                    self._speaking = False
                    self.status    = "Prête"

        self._tts_thread = threading.Thread(target=_run, daemon=True, name="ASSISTA-TTS")
        self._tts_thread.start()
        return {"ok": True, "message": f"🔊 {truncate(clean, 60)}"}

    def _request_stop_tts(self, wait: float = 0.8) -> None:
        """Signale au thread TTS actif de s'arreter et evite les lectures superposees."""
        if self._tts_stop_evt is not None:
            self._tts_stop_evt.set()
        if self._tts_thread and self._tts_thread.is_alive():
            self._tts_thread.join(timeout=wait)
        with self._lock:
            self._speaking = False

    def stop_speaking(self) -> Dict:
        """Arrête immédiatement la lecture TTS en cours. Relançable ensuite."""
        self._request_stop_tts(wait=1.2)
        with self._lock:
            self.status = "Prête"
        return {"ok": True, "message": "🔇 Lecture arrêtée."}

    # ── STT ───────────────────────────────────────────────────────────────
    def start_listening(self) -> Dict:
        if sr is None:
            return {"ok": False, "message": "SpeechRecognition manquant (pip install SpeechRecognition)."}
        if self._listening:
            return {"ok": True, "message": "Déjà en écoute."}

        mic_index  = choose_microphone_index()
        recognizer = sr.Recognizer()
        recognizer.dynamic_energy_threshold = True
        recognizer.pause_threshold = 1.0

        def _callback(recognizer, audio):
            try:
                text  = recognizer.recognize_google(audio, language="fr-FR").strip()
                if not text:
                    return
                lower = normalize_text(text)
                with self._lock:
                    awake = self._awake
                    hf    = getattr(self._brain, "hands_free", False)
                if any(w in lower for w in WAKE_WORDS) and not awake:
                    with self._lock:
                        self._awake = True
                    self._brain.mark_wake_event(text)
                    self.speak("Bonjour, je vous écoute.")
                    return
                if any(w in lower for w in SLEEP_WORDS) and awake:
                    with self._lock:
                        self._awake = False
                    self._brain.mark_sleep_event(text)
                    self.speak("Je repasse en veille. À bientôt.")
                    return
                if awake or hf:
                    self._brain.submit(text, source="voice")
            except sr.UnknownValueError:
                pass
            except Exception:
                pass

        try:
            mic = sr.Microphone(device_index=mic_index)
            self._stop_fn = recognizer.listen_in_background(
                mic, _callback, phrase_time_limit=10
            )
            with self._lock:
                self._listening = True
                # En mains libres, on se réveille directement
                if getattr(self._brain, "hands_free", False):
                    self._awake = True
                self.status = "Micro actif — en écoute"
            return {"ok": True, "message": "🎙 Micro activé. Dites 'salut' pour me réveiller."}
        except Exception as e:
            return {"ok": False, "message": f"Échec activation micro : {e}"}

    def stop_listening(self) -> Dict:
        if self._stop_fn:
            try:
                self._stop_fn(wait_for_stop=False)
            except Exception:
                pass
            self._stop_fn = None
        with self._lock:
            self._listening = False
            self.status     = "Micro désactivé"
        return {"ok": True, "message": "🔇 Micro désactivé."}

    def toggle_auto_speak(self, enabled: bool) -> Dict:
        self.auto_speak = bool(enabled)
        msg = "Auto-lecture activée." if self.auto_speak else "Auto-lecture désactivée."
        return {"ok": True, "message": msg}

    def get_state(self) -> Dict:
        with self._lock:
            return {
                "listening": self._listening,
                "speaking":  self._speaking,
                "awake":     self._awake,
                "status":    self.status,
                "volume":    self._volume,
            }

    def refresh_idle(self) -> None:
        with self._lock:
            if not self._listening and not self._speaking:
                self.status = "Micro désactivé" if not self._awake else "Prête"



