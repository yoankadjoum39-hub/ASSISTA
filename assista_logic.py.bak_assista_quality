#  CERVEAU PRINCIPAL V2 — AssistaBrainV2
# ══════════════════════════════════════════════════════════════════════════════
class AssistaBrainV2:
    """
    Cerveau ASSISTA v2 — orchestration complète.

    API publique (compatible pywebview) :
      bootstrap()
      submit(prompt, source)
      approve_plan(id) / reject_plan(id)
      set_autopilot(bool)
      start_voice() / stop_voice() / set_auto_speak(bool)
      speak_last_response()
      get_state()
      get_config() / save_config(...)
      get_shell_log(n)
      forget_memory()
      get_memory()
      get_db_stats()
      scan_pc(full)
      get_pcmap_stats()
      poll_js()
      analyze_local_path(path_str)
    """

    def __init__(self, user_name: str) -> None:
        self.user_name = user_name or "Utilisateur"
        self._lock     = threading.RLock()

        # Couches
        self.db       = AssistaDatabaseV2()
        self.config   = AssistaConfig(self.db)
        self.memory   = AssistaMemory(self.db)
        self.context  = AssistaDesktopContext()
        self.shell    = AssistaShell(self.db)
        self.policy   = AssistaPermissionPolicyV2()
        self.registry = AssistaActionRegistryV2(self.shell, self.db, self.context, brain_ref=self)
        self.llm      = AssistaLLM(self.config)
        self.mapper   = AssistaPCMapper(self.db)
        self.voice    = AssistaVoice(self)
        # Modèle d'apprentissage (optionnel)
        self.training_model = AssistaTrainingModel(ASSISTA_MODEL_DB_PATH) if AssistaTrainingModel else None

        # État interne
        self._conv_id        = str(uuid.uuid4())
        self._history:       List[Dict] = []
        self._pending_plan:  Optional[TaskPlan] = None
        self._bootstrapped   = False
        self._busy           = False
        self._status         = ""
        self._last_response  = ""
        self._streaming_text = ""
        self.autopilot       = False
        self.hands_free      = False    # mode mains libres (voix permanente)
        self._voice_confirm  = False
        self._voice_confirm_prompt = ""
        self._js_queue: List[str] = []
        self._js_lock   = threading.Lock()
        # Restaurer les préférences persistantes dès le départ
        self.autopilot   = self.db.pref_get("autopilot", "false") == "true"
        self.hands_free  = self.db.pref_get("hands_free", "false") == "true"
        _auto_speak = self.db.pref_get("auto_speak", "false") == "true"
        self.voice.auto_speak = _auto_speak

    # ── Bootstrap ─────────────────────────────────────────────────────────────
    def bootstrap(self) -> Dict:
        with self._lock:
            if self._bootstrapped:
                # Déjà initialisé : retourne juste l'état courant sans nouveau message
                return self._state()
            self._bootstrapped = True
            # Préférences
            user_pref = self.db.pref_get("user.name", self.user_name)
            if user_pref:
                self.user_name = user_pref
            # Démarrer le PC Mapper en arrière-plan (scan léger)
            self.mapper.start(full=False)
            pcmap_count = self.db.pcmap_count()
            scan_msg = (f" (cartographie PC : {pcmap_count} entrées)"
                        if pcmap_count > 0 else " (scan PC en cours…)")
            msg = (
                f"Bonjour {self.user_name} ! Je suis **ASSISTA v2**, votre assistante PC de nouvelle génération.{scan_msg}\n\n"
                f"Je dispose de **10 agents spécialisés**, d'une base SQLite complète, "
                f"et de nouveaux outils puissants : clipboard, notifications, planificateur, git, réseau, sécurité et plus encore.\n\n"
                "Comment puis-je vous aider ?"
            )
            self._push("assista", msg)
            return self._state(msg)

    # ── Soumission ────────────────────────────────────────────────────────────
    def submit(self, prompt: str, source: str = "text") -> Dict:
        raw = (prompt or "").strip()
        if not raw:
            return self._state("Aucune demande reçue.")
        if raw == "context_snapshot_internal":
            return self._state(json.dumps(self.context.snapshot(), ensure_ascii=False, indent=2))
        with self._lock:
            if self._busy:
                return self._state("Je traite déjà une demande, patientez…")
            self._push("user", raw)
            lower = normalize_text(raw)
            if self._pending_plan and lower in {"oui", "ok", "vas-y", "go", "confirme", "autorise"}:
                return self.approve_plan(self._pending_plan.id)
            if self._pending_plan and lower in {"non", "annule", "stop", "refuse", "cancel"}:
                return self.reject_plan(self._pending_plan.id)
            self._busy   = True
            self._status = "Analyse…"
        threading.Thread(target=self._worker, args=(raw, source), daemon=True).start()
        return self._state("Traitement en cours…")

    # ── Plan approval ─────────────────────────────────────────────────────────
    def approve_plan(self, plan_id: str) -> Dict:
        with self._lock:
            if self._busy:
                return self._state("Je suis déjà occupée.")
            if not self._pending_plan or self._pending_plan.id != plan_id:
                return self._state("Aucun plan en attente.")
            plan = self._pending_plan
            self._pending_plan = None
            self._busy   = True
            self._status = "Exécution du plan…"
        threading.Thread(target=self._execute_plan_bg, args=(plan, "✅ Plan approuvé."), daemon=True).start()
        return self._state("Exécution en cours…")

    def reject_plan(self, plan_id: str) -> Dict:
        with self._lock:
            if not self._pending_plan or self._pending_plan.id != plan_id:
                return self._state("Aucun plan en attente.")
            plan = self._pending_plan
            self._pending_plan = None
            msg = f"Plan annulé : {plan.summary}"
            self._push("assista", msg)
            self._last_response = msg
            return self._state(msg)

