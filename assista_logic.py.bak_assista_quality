    def _notify(self, p: "ActionProposal") -> Dict:
        title = p.title or "ASSISTA"
        body  = (p.command or p.target or p.summary or "").strip()
        self._db.notif_add(title, body, "toast")
        # Tentative notification native
        sent = False
        if platform.system() == "Windows":
            try:
                from win10toast import ToastNotifier  # type: ignore
                ToastNotifier().show_toast(title, body, duration=5, threaded=True)
                sent = True
            except Exception:
                pass
            if not sent:
                # Fallback PowerShell
                cmd = (
                    f'Add-Type -AssemblyName System.Windows.Forms; '
                    f'$n = New-Object System.Windows.Forms.NotifyIcon; '
                    f'$n.Icon = [System.Drawing.SystemIcons]::Information; '
                    f'$n.BalloonTipTitle = "{title}"; '
                    f'$n.BalloonTipText = "{body}"; '
                    f'$n.Visible = $true; '
                    f'$n.ShowBalloonTip(3000)'
                )
                self._shell.run(cmd)
                sent = True
        elif platform.system() == "Darwin":
            try:
                subprocess.run(
                    ["osascript", "-e", f'display notification "{body}" with title "{title}"'],
                    check=True, capture_output=True
                )
                sent = True
            except Exception:
                pass
        else:
            try:
                subprocess.run(["notify-send", title, body], check=True, capture_output=True)
                sent = True
            except Exception:
                pass
        return {"ok": True, "message": f"🔔 Notification envoyée : **{title}** — {body}"}


class AgentPlanificateur(AgentBase):
    """Planification de tâches."""
    name = "AgentPlanificateur"

    def __init__(self, shell: AssistaShell, db: AssistaDatabaseV2,
                 ctx: AssistaDesktopContext, brain_ref=None):
        super().__init__(shell, db, ctx)
        self._brain = brain_ref
        self._timer_thread: Optional[threading.Thread] = None

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k == "schedule":         return self._schedule(p)
        if k == "schedule_list":    return self._list(p)
        if k == "schedule_cancel":  return self._cancel(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentPlanificateur : {k}"}

    def _schedule(self, p: "ActionProposal") -> Dict:
        label      = p.title or p.target
        command    = (p.command or p.target).strip()
        interval_s = int(p.meta.get("interval_s", 0))
        delay_s    = int(p.meta.get("delay_s", 0))
        run_at_str = p.meta.get("run_at", "")

        if delay_s > 0:
            run_at = (datetime.now() + timedelta(seconds=delay_s)).strftime("%Y-%m-%d %H:%M:%S")
        elif run_at_str:
            run_at = run_at_str
        else:
            run_at = now_iso()

        task = ScheduledTask(
            id=str(uuid.uuid4()), label=label, command=command,
            kind=p.meta.get("kind", "run_shell"),
            run_at=run_at, interval_s=interval_s, next_run=run_at
        )
        self._db.task_add(task)
        self._ensure_scheduler()
        eta = f" dans {delay_s}s" if delay_s else f" à {run_at}"
        rpt = f" (répétition toutes les {interval_s}s)" if interval_s else ""
        return {"ok": True, "message": f"⏰ Tâche planifiée{eta}{rpt} : `{label}`"}

    def _list(self, p: "ActionProposal") -> Dict:
        tasks = self._db.task_list()
        if not tasks:
            return {"ok": True, "message": "Aucune tâche planifiée."}
        lines = [f"⏰ **Tâches planifiées ({len(tasks)}) :**\n"]
        for t in tasks:
            lines.append(f"  • **{t['label']}** — prochaine : {t.get('next_run','?')}")
        return {"ok": True, "message": "\n".join(lines)}

    def _cancel(self, p: "ActionProposal") -> Dict:
        tid = (p.target or p.meta.get("id", "")).strip()
        if not tid:
            return {"ok": False, "message": "ID de tâche manquant."}
        self._db.task_delete(tid)
        return {"ok": True, "message": f"✅ Tâche annulée."}

    def _ensure_scheduler(self) -> None:
        if self._timer_thread and self._timer_thread.is_alive():
            return
        self._timer_thread = threading.Thread(
            target=self._scheduler_loop, daemon=True, name="Scheduler"
        )
        self._timer_thread.start()

    def _scheduler_loop(self) -> None:
        while True:
            time.sleep(5)
            try:
                now = datetime.now()
                for task in self._db.task_list():
                    next_run = task.get("next_run")
                    if not next_run:
                        continue
                    try:
                        next_dt = datetime.strptime(next_run, "%Y-%m-%d %H:%M:%S")
                    except Exception:
                        continue
                    if now >= next_dt:
                        # Exécuter
                        try:
                            self._shell.run(task["command"])
                        except Exception:
                            pass
                        last = now_iso()
                        interval = task.get("interval_s", 0)
                        if interval > 0:
                            nxt = (now + timedelta(seconds=interval)).strftime("%Y-%m-%d %H:%M:%S")
                        else:
                            nxt = None
                            self._db.task_delete(task["id"])
                            continue
                        self._db.task_update_run(task["id"], last, nxt)
            except Exception:
                pass


class AgentSecurite(AgentBase):
    """Sécurité : audit, hash, ports ouverts."""
    name = "AgentSecurite"

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k == "hash_file":    return AgentFichiers(self._shell, self._db, self._ctx)._hash_file(p)
        if k == "audit_log":    return self._audit_log(p)
        if k == "security_scan": return self._security_scan(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentSecurite : {k}"}

    def _audit_log(self, p: "ActionProposal") -> Dict:
        n       = int(p.meta.get("n", 30))
        entries = self._db.audit_get(n)
        if not entries:
            return {"ok": True, "message": "Journal d'audit vide."}
        lines = [f"🔐 **Dernières {len(entries)} commandes auditées :**\n"]
        for e in entries:
            icon = "✅" if e["status"] == "OK" else ("🚫" if e["status"] == "BLOCKED" else "⚠️")
            lines.append(f"  {icon} [{e['ts']}] {truncate(e['command'], 60)} — {e['status']}")
        return {"ok": True, "message": "\n".join(lines)}

    def _security_scan(self, p: "ActionProposal") -> Dict:
        lines = ["🛡️ **Scan de sécurité :**\n"]
        # Processus suspects (noms communs de malwares)
        suspects = {"mimikatz", "netcat", "nc.exe", "nmap", "metasploit", "meterpreter"}
        if psutil:
            for proc in psutil.process_iter(["pid", "name"]):
                try:
                    name = (proc.info.get("name") or "").lower()
                    if any(s in name for s in suspects):
                        lines.append(f"  ⚠️ Processus suspect : `{proc.info['name']}` (PID {proc.info['pid']})")
                except Exception:
                    pass
        # Ports ouverts locaux
        if psutil:
            try:
                conns = psutil.net_connections()
                listening = [c for c in conns if c.status == "LISTEN"]
                lines.append(f"\n• Ports en écoute ({len(listening)}) :")
                for c in listening[:20]:
                    lines.append(f"  Port {c.laddr.port}")
            except Exception:
                pass
        if len(lines) == 1:
            lines.append("  ✅ Aucune anomalie détectée.")
        return {"ok": True, "message": "\n".join(lines)}

