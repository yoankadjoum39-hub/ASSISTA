#  COUCHE 3 — CONFIG
# ══════════════════════════════════════════════════════════════════════════════
class AssistaConfig:
    _DEFAULTS = {
        "api_key":  "",
        "model":    DEFAULT_MODEL,
        "base_url": DEFAULT_BASE_URL,
    }

    def __init__(self, db: AssistaDatabaseV2):
        self._db = db

    def load(self) -> Dict:
        cfg = dict(self._DEFAULTS)
        for k in cfg:
            v = self._db.pref_get(f"config.{k}")
            if v is not None:
                cfg[k] = v
        # Fallback fichier JSON legacy
        if not cfg["api_key"] and CONFIG_PATH.exists():
            try:
                old = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
                cfg["api_key"]  = old.get("api_key",  cfg["api_key"])
                cfg["model"]    = old.get("model",    cfg["model"])
                cfg["base_url"] = old.get("base_url", cfg["base_url"])
            except Exception:
                pass
        # Clé API : priorité variable d'environnement si champ vide
        env_key = os.getenv("OPENROUTER_API_KEY", "").strip()
        if not cfg["api_key"] and env_key:
            cfg["api_key"]         = env_key
            cfg["api_key_from_env"] = True
        else:
            cfg["api_key_from_env"] = False
        # URL par défaut pré-remplie
        if not cfg["base_url"]:
            cfg["base_url"] = DEFAULT_BASE_URL
        return cfg

    def save(self, api_key: str, model: str, base_url: str) -> Dict:
        cfg = {
            "api_key":  (api_key  or "").strip(),
            "model":    (model    or DEFAULT_MODEL).strip(),
            "base_url": (base_url or DEFAULT_BASE_URL).strip(),
        }
        for k, v in cfg.items():
            self._db.pref_set(f"config.{k}", v)
        return cfg

