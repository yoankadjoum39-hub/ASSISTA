    def set_hands_free(self, enabled: bool) -> Dict:
        """Active/désactive le mode mains libres (voix permanente + auto-speak)."""
        with self._lock:
            self.hands_free = bool(enabled)
            self.db.pref_set("hands_free", str(self.hands_free).lower())
            if self.hands_free:
                self.voice.auto_speak = True
                self.db.pref_set("auto_speak", "true")
                with self.voice._lock:
                    self.voice._awake = True
                msg = "🎙 Mode mains libres activé. Je vous écoute et réponds à voix haute."
            else:
                msg = "🔇 Mode mains libres désactivé."
            self._push("assista", msg)
            self._last_response = msg
        if enabled:
            self.voice.speak(msg)
        return self._state(msg)

    def teach_assista_model(
        self,
        user_phrase: str,
        kind: str,
        target: str = "",
        command: str = "",
        explanation: str = "",
    ) -> Dict:
        """Enseigne une nouvelle correspondance phrase→action au modèle d'apprentissage."""
        if not self.training_model:
            return {"ok": False, "message": "Modèle d'apprentissage non disponible."}
        result = self.training_model.learn(user_phrase, kind, target, command, explanation)
        if result.get("ok"):
            msg = result.get("message", "Leçon enregistrée.")
            self._push("assista", f"🎓 {msg}")
        return result

