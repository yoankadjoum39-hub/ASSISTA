class AssistaDesktopContext:
    def __init__(self) -> None:
        self.home                = Path.home()
        self.last_capture_path:  Optional[Path] = None
        self.last_ocr_text       = ""

    def snapshot(self) -> Dict:
        roots = [
            ("Desktop",   self.home / "Desktop"),
            ("Documents", self.home / "Documents"),
            ("Downloads", self.home / "Downloads"),
            ("Pictures",  self.home / "Pictures"),
            ("Music",     self.home / "Music"),
            ("Project",   PROJECT_ROOT),
        ]
        return {
            "timestamp":     now_iso(),
            "os":            platform.system(),
            "os_version":    platform.version(),
            "hostname":      socket.gethostname(),
            "active_window": get_active_window_title(),
            "home":          str(self.home),
            "roots":         [
                {"label": l, "path": str(p), "exists": "yes" if p.exists() else "no"}
                for l, p in roots
            ],
            "recent_capture": str(self.last_capture_path) if self.last_capture_path else "",
            "recent_ocr":    truncate(self.last_ocr_text, 300),
            "capabilities": {
                "screen_capture": ImageGrab is not None,
                "ocr":            pytesseract is not None and bool(TESSERACT_PATH),
                "tts":            pyttsx3 is not None,
                "stt":            sr is not None,
                "clipboard":      pyperclip is not None,
                "psutil":         psutil is not None,
                "pdf_read":       PdfReader is not None,
                "word_read":      DocxDocument is not None,
                "excel_read":     openpyxl is not None,
            },
        }

    def capture_screen(self) -> Dict:
        if ImageGrab is None:
            return {"ok": False, "message": "Pillow manquant."}
        stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        path  = CAPTURE_DIR / f"assista_{stamp}.png"
        try:
            img = ImageGrab.grab(all_screens=True)
            img.save(path)
            self.last_capture_path = path
            return {"ok": True, "message": f"Capture enregistrée : {path}", "path": str(path)}
        except Exception as e:
            return {"ok": False, "message": f"Échec capture : {e}"}

    def analyze_screen(self) -> Dict:
        cap = self.capture_screen()
        if not cap.get("ok"):
            return cap
        if pytesseract is None or not TESSERACT_PATH:
            return {"ok": True, "message": f"Capture : {cap['path']}\nOCR indisponible.", "path": cap["path"]}
        try:
            img = ImageGrab.grab(all_screens=True)
            self.last_ocr_text = pytesseract.image_to_string(img, lang="eng+fra").strip()
            return {
                "ok": True, "path": cap["path"],
                "message": f"Capture : {cap['path']}\nTexte OCR :\n{truncate(self.last_ocr_text, 4000)}",
                "ocr": self.last_ocr_text,
            }
        except Exception as e:
            return {"ok": False, "message": f"Échec OCR : {e}"}

    # ── Contrôle clavier / souris (Windows) ───────────────────────────────
    def screen_preview_data_uri(self, max_width: int = 960) -> Dict:
        """Capture l'écran et retourne un data URI JPEG (pour l'UI)."""
        if ImageGrab is None:
            return {"ok": False, "message": "Pillow manquant."}
        try:
            img = ImageGrab.grab(all_screens=True)
            if max_width and img.width > max_width:
                ratio = max_width / float(img.width)
                img = img.resize((int(img.width * ratio), int(img.height * ratio)))
            buf = io.BytesIO()
            img.save(buf, format="JPEG", quality=72)
            data = base64.b64encode(buf.getvalue()).decode("ascii")
            return {"ok": True, "data_uri": f"data:image/jpeg;base64,{data}",
                    "width": img.width, "height": img.height}
        except Exception as e:
            return {"ok": False, "message": f"Échec aperçu : {e}"}

    def click_at(self, x: int, y: int) -> Dict:
        """Déplace et clique la souris à (x, y) — Windows uniquement."""
        if platform.system() != "Windows":
            return {"ok": False, "message": "Contrôle souris Windows uniquement."}
        try:
            u32 = ctypes.windll.user32
            u32.SetCursorPos(int(x), int(y))
            u32.mouse_event(0x0002, 0, 0, 0, 0)
            u32.mouse_event(0x0004, 0, 0, 0, 0)
            return {"ok": True, "message": f"Clic en ({x}, {y})."}
        except Exception as e:
            return {"ok": False, "message": f"Échec clic : {e}"}

    def click_text(self, text: str) -> Dict:
        """Cherche le texte à l'écran via OCR et clique dessus."""
        query = normalize_text(text)
        if not query:
            return {"ok": False, "message": "Texte vide."}
        if ImageGrab is None or pytesseract is None or not TESSERACT_PATH:
            return {"ok": False, "message": "Clic OCR indisponible (Pillow/Tesseract manquant)."}
        try:
            img  = ImageGrab.grab(all_screens=True)
            data = pytesseract.image_to_data(img, lang="eng+fra",
                                             output_type=pytesseract.Output.DICT)
            words = []
            for i, raw in enumerate(data.get("text", [])):
                w = normalize_text(raw)
                if w:
                    words.append((w, data["left"][i], data["top"][i],
                                  data["width"][i], data["height"][i]))
            q_parts = query.split()
            for i in range(len(words)):
                candidate = " ".join(w[0] for w in words[i:i+len(q_parts)])
                if query in candidate:
                    chunk  = words[i:i+len(q_parts)]
                    cx = (min(w[1] for w in chunk) + max(w[1]+w[3] for w in chunk)) // 2
                    cy = (min(w[2] for w in chunk) + max(w[2]+w[4] for w in chunk)) // 2
                    return self.click_at(cx, cy)
            return {"ok": False, "message": f"Texte non trouvé : {text}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur OCR clic : {e}"}

    def type_text(self, text: str) -> Dict:
        """Tape du texte via le presse-papiers + Ctrl+V."""
        if not text:
            return {"ok": False, "message": "Texte vide."}
        if platform.system() != "Windows":
            return {"ok": False, "message": "Saisie automatique Windows uniquement."}
        if write_clipboard_text(text):
            self.hotkey(["ctrl", "v"])
            return {"ok": True, "message": f"Texte saisi ({len(text)} caractères)."}
        return {"ok": False, "message": "Impossible d'écrire dans le presse-papiers."}

    def press_key(self, key: str) -> Dict:
        """Appuie sur une touche (par nom)."""
        vk = _vk_key(key)
        if not vk:
            return {"ok": False, "message": f"Touche inconnue : {key}"}
        _send_vk(vk, True)
        time.sleep(0.03)
        _send_vk(vk, False)
        return {"ok": True, "message": f"Touche : {key}"}

    def hotkey(self, keys: List[str]) -> Dict:
        """Envoie un raccourci clavier (ex: ['ctrl','c'])."""
        vks = [_vk_key(k) for k in keys if _vk_key(k)]
        if not vks:
            return {"ok": False, "message": "Raccourci vide ou inconnu."}
        for vk in vks:
            _send_vk(vk, True)
            time.sleep(0.02)
        for vk in reversed(vks):
            _send_vk(vk, False)
            time.sleep(0.02)
        return {"ok": True, "message": "Raccourci : " + "+".join(keys)}

    def control_window(self, action: str) -> Dict:
        """Minimise, maximise, restaure ou ferme la fenêtre active."""
        if platform.system() != "Windows":
            return {"ok": False, "message": "Contrôle fenêtres Windows uniquement."}
        hwnd = _get_foreground_hwnd()
        if not hwnd:
            return {"ok": False, "message": "Aucune fenêtre active."}
        a = normalize_text(action)
        cmds = {"minimize":6,"minimise":6,"reduis":6,"maximize":3,"agrandis":3,
                "restore":9,"restaure":9,"normal":9}
        try:
            if a in {"close","ferme","fermer"}:
                ctypes.windll.user32.PostMessageW(hwnd, 0x0010, 0, 0)
            else:
                ctypes.windll.user32.ShowWindow(hwnd, cmds.get(a, 9))
            return {"ok": True, "message": f"Fenêtre : {action}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur fenêtre : {e}"}

