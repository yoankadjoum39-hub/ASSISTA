class AgentBase:
    """Base commune pour tous les agents."""
    name = "AgentBase"

    def __init__(self, shell: AssistaShell, db: AssistaDatabaseV2, ctx: AssistaDesktopContext):
        self._shell = shell
        self._db    = db
        self._ctx   = ctx

    def execute(self, proposal: "ActionProposal") -> Dict:
        raise NotImplementedError


class AgentFichiers(AgentBase):
    """Gestion complète des fichiers."""
    name = "AgentFichiers"

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k in ("read_file",):             return self._read_file(p)
        if k in ("create_text_file", "write_file"): return self._create_file(p)
        if k == "delete_file":              return self._delete_file(p)
        if k in ("move_file",):             return self._move_file(p)
        if k == "copy_file":                return self._copy_file(p)
        if k in ("list_dir",):              return self._list_dir(p)
        if k in ("search_files",):          return self._search_files(p)
        if k == "search_file_content":      return self._search_content(p)
        if k == "zip_files":                return self._zip_files(p)
        if k == "extract_zip":              return self._extract_zip(p)
        if k == "hash_file":                return self._hash_file(p)
        if k == "diff_files":               return self._diff_files(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentFichiers : {k}"}

    def _list_dir(self, p: "ActionProposal") -> Dict:
        aliases = {
            "bureau": str(self._ctx.home / "Desktop"),
            "desktop": str(self._ctx.home / "Desktop"),
            "documents": str(self._ctx.home / "Documents"),
            "downloads": str(self._ctx.home / "Downloads"),
            "téléchargements": str(self._ctx.home / "Downloads"),
            "telechargements": str(self._ctx.home / "Downloads"),
            "pictures": str(self._ctx.home / "Pictures"),
            "images": str(self._ctx.home / "Pictures"),
            "musique": str(self._ctx.home / "Music"),
            "music": str(self._ctx.home / "Music"),
            "videos": str(self._ctx.home / "Videos"),
            "project": str(PROJECT_ROOT),
        }
        target = p.target.strip()
        path   = Path(aliases.get(target.lower(), target))
        if not path.exists():
            return {"ok": False, "message": f"Dossier introuvable : {path}"}
        try:
            items = sorted(path.iterdir(), key=lambda x: (not x.is_dir(), x.name.lower()))
            lines = [f"📁 {path}\n"]
            for item in items[:100]:
                icon = "📁" if item.is_dir() else "📄"
                size = ""
                if item.is_file():
                    try: size = f" ({human_size(item.stat().st_size)})"
                    except Exception: pass
                lines.append(f"{icon} {item.name}{size}")
            total = sum(1 for _ in path.iterdir())
            if total > 100:
                lines.append(f"… {total} éléments au total")
            return {"ok": True, "message": "\n".join(lines)}
        except PermissionError:
            return {"ok": False, "message": f"Accès refusé : {path}"}

    def _read_file(self, p: "ActionProposal") -> Dict:
        path = Path(p.target.strip())
        if not path.exists():
            return {"ok": False, "message": f"Fichier introuvable : {path}"}
        ext = path.suffix.lower()
        if ext == ".pdf":
            if PdfReader is None:
                return {"ok": False, "message": "pypdf non installé"}
            try:
                reader = PdfReader(str(path))
                text   = "\n".join(pg.extract_text() or "" for pg in reader.pages)
                return {"ok": True, "message": f"📄 {path.name}\n\n{truncate(text, MAX_FILE_CHARS)}"}
            except Exception as e:
                return {"ok": False, "message": f"Erreur PDF : {e}"}
        if ext == ".docx":
            if DocxDocument is None:
                return {"ok": False, "message": "python-docx non installé"}
            try:
                doc  = DocxDocument(str(path))
                text = "\n".join(pg.text for pg in doc.paragraphs)
                return {"ok": True, "message": f"📄 {path.name}\n\n{truncate(text, MAX_FILE_CHARS)}"}
            except Exception as e:
                return {"ok": False, "message": f"Erreur DOCX : {e}"}
        if ext in {".xlsx", ".xlsm"}:
            if openpyxl is None:
                return {"ok": False, "message": "openpyxl non installé"}
            try:
                wb    = openpyxl.load_workbook(str(path), read_only=True, data_only=True)
                lines = []
                for ws in wb.worksheets[:3]:
                    lines.append(f"=== {ws.title} ===")
                    for row in ws.iter_rows(max_row=50, values_only=True):
                        lines.append("\t".join(str(c) if c is not None else "" for c in row))
                return {"ok": True, "message": f"📊 {path.name}\n\n{truncate(chr(10).join(lines), MAX_FILE_CHARS)}"}
            except Exception as e:
                return {"ok": False, "message": f"Erreur Excel : {e}"}
        if ext in TEXT_EXTENSIONS or ext == "":
            try:
                text = path.read_text(encoding="utf-8", errors="replace")
                return {"ok": True, "message": f"📄 {path.name}\n\n{truncate(text, MAX_FILE_CHARS)}"}
            except Exception as e:
                return {"ok": False, "message": f"Erreur lecture : {e}"}
        return {"ok": False, "message": f"Type non supporté : {ext}"}

    def _create_file(self, p: "ActionProposal") -> Dict:
        raw_target = p.target.strip()
        content = str(p.meta.get("content", "")).strip()
        # ── Résolution des alias de dossiers courants ──
        home = self._ctx.home
        folder_aliases = {
            "bureau":          str(home / "Desktop"),
            "desktop":         str(home / "Desktop"),
            "documents":       str(home / "Documents"),
            "downloads":       str(home / "Downloads"),
            "téléchargements": str(home / "Downloads"),
            "telechargements": str(home / "Downloads"),
            "images":          str(home / "Pictures"),
            "pictures":        str(home / "Pictures"),
            "musique":         str(home / "Music"),
            "music":           str(home / "Music"),
            "videos":          str(home / "Videos"),
            "vidéos":          str(home / "Videos"),
        }
        # Résolution des chemins relatifs commençant par un alias
        resolved_target = raw_target
        lower_target = raw_target.lower().replace("\\", "/")
        for alias, real_path in folder_aliases.items():
            if lower_target.startswith(alias + "/") or lower_target == alias:
                resolved_target = raw_target.replace(raw_target.split("/")[0], real_path, 1)
                break
            # Cas: "bureau\fichier.txt" (Windows)
            if lower_target.startswith(alias + "\\"):
                resolved_target = real_path + "\\" + raw_target.split("\\", 1)[1]
                break
        # Si le chemin est juste un nom de fichier sans dossier, le mettre sur le bureau
        path = Path(resolved_target)
        if not path.is_absolute() and "/" not in resolved_target and "\\" not in resolved_target:
            # Nom de fichier seul → on le place sur le bureau par défaut
            path = home / "Desktop" / path.name
        try:
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(content, encoding="utf-8")
            return {"ok": True, "message": f"✅ Fichier créé : {path}"}
        except Exception as e:
            return {"ok": False, "message": f"Échec : {e}"}

    def _delete_file(self, p: "ActionProposal") -> Dict:
        path = Path(p.target.strip())
        if not path.exists():
            return {"ok": False, "message": f"Introuvable : {path}"}
        try:
            if path.is_dir():
                shutil.rmtree(str(path))
            else:
                path.unlink()
            return {"ok": True, "message": f"🗑️ Supprimé : {path}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}

    def _move_file(self, p: "ActionProposal") -> Dict:
        src = Path(p.target.strip())
        dst = Path(str(p.meta.get("destination", "")).strip())
        if not src.exists():
            return {"ok": False, "message": f"Source introuvable : {src}"}
        try:
            src.rename(dst)
            return {"ok": True, "message": f"📦 Déplacé : {src} → {dst}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}

    def _copy_file(self, p: "ActionProposal") -> Dict:
        src = Path(p.target.strip())
        dst = Path(str(p.meta.get("destination", "")).strip())
        if not src.exists():
            return {"ok": False, "message": f"Source introuvable : {src}"}
        try:
            dst.parent.mkdir(parents=True, exist_ok=True)
            if src.is_dir(): shutil.copytree(str(src), str(dst))
            else:            shutil.copy2(str(src), str(dst))
            return {"ok": True, "message": f"📋 Copié : {src} → {dst}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}

    def _search_files(self, p: "ActionProposal") -> Dict:
        root  = Path(p.target or str(self._ctx.home))
        query = normalize_text(p.meta.get("query", p.target))
        # Chercher d'abord dans la DB
        db_results = self._db.pcmap_search(query, limit=MAX_SEARCH_RESULTS)
        if db_results:
            lines = [f"🔍 Résultats DB ({len(db_results)}) :"]
            for r in db_results:
                lines.append(f"  {'📁' if r['type']=='dir' else '📄'} {r['path']}")
            return {"ok": True, "message": "\n".join(lines)}
        # Fallback scan live
        if not root.exists():
            return {"ok": False, "message": f"Dossier introuvable : {root}"}
        matches = []
        try:
            for item in root.rglob("*"):
                if query in normalize_text(item.name):
                    matches.append(str(item))
                    if len(matches) >= MAX_SEARCH_RESULTS:
                        break
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}
        if not matches:
            return {"ok": True, "message": f"Aucun fichier pour '{query}'"}
        return {"ok": True, "message": "\n".join(matches)}

    def _search_content(self, p: "ActionProposal") -> Dict:
        root  = Path(p.target or str(self._ctx.home))
        query = normalize_text(p.meta.get("query", p.target))
        if not root.exists():
            return {"ok": False, "message": f"Dossier introuvable : {root}"}
        results = []
        try:
            for fpath in root.rglob("*"):
                if not fpath.is_file() or fpath.suffix.lower() not in TEXT_EXTENSIONS:
                    continue
                try:
                    content = fpath.read_text(encoding="utf-8", errors="ignore")
                    if query in normalize_text(content):
                        for i, line in enumerate(content.splitlines()):
                            if query in normalize_text(line):
                                results.append(f"{fpath}:{i+1}: {line.strip()[:120]}")
                                break
                        if len(results) >= MAX_SEARCH_RESULTS:
                            break
                except Exception:
                    continue
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}
        if not results:
            return {"ok": True, "message": f"Aucun contenu pour '{query}'"}
        return {"ok": True, "message": "\n".join(results)}

    def _zip_files(self, p: "ActionProposal") -> Dict:
        sources = p.meta.get("sources", [p.target])
        dest    = p.meta.get("destination", str(Path(p.target).with_suffix(".zip")))
        try:
            with zipfile.ZipFile(dest, "w", zipfile.ZIP_DEFLATED) as zf:
                for src in sources:
                    src_path = Path(src)
                    if src_path.is_dir():
                        for f in src_path.rglob("*"):
                            if f.is_file():
                                zf.write(f, f.relative_to(src_path.parent))
                    elif src_path.is_file():
                        zf.write(src_path, src_path.name)
            return {"ok": True, "message": f"📦 ZIP créé : {dest}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur ZIP : {e}"}

    def _extract_zip(self, p: "ActionProposal") -> Dict:
        src  = Path(p.target.strip())
        dest = Path(p.meta.get("destination", str(src.parent / src.stem)))
        if not src.exists():
            return {"ok": False, "message": f"Archive introuvable : {src}"}
        try:
            dest.mkdir(parents=True, exist_ok=True)
            with zipfile.ZipFile(str(src), "r") as zf:
                zf.extractall(str(dest))
            return {"ok": True, "message": f"📂 Extrait dans : {dest}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur extraction : {e}"}

    def _hash_file(self, p: "ActionProposal") -> Dict:
        path = Path(p.target.strip())
        algo = p.meta.get("algo", "sha256").lower()
        if not path.exists():
            return {"ok": False, "message": f"Fichier introuvable : {path}"}
        try:
            h = hashlib.new(algo)
            with open(path, "rb") as f:
                for chunk in iter(lambda: f.read(65536), b""):
                    h.update(chunk)
            digest = h.hexdigest()
            return {"ok": True, "message": f"🔒 {algo.upper()} de `{path.name}` :\n`{digest}`"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur hash : {e}"}

    def _diff_files(self, p: "ActionProposal") -> Dict:
        import difflib
        src  = Path(p.target.strip())
        dest = Path(str(p.meta.get("destination", "")).strip())
        if not src.exists():
            return {"ok": False, "message": f"Fichier A introuvable : {src}"}
        if not dest.exists():
            return {"ok": False, "message": f"Fichier B introuvable : {dest}"}
        try:
            a = src.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)
            b = dest.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)
            diff = list(difflib.unified_diff(a, b, fromfile=src.name, tofile=dest.name, n=3))
            if not diff:
                return {"ok": True, "message": "✅ Les fichiers sont identiques."}
            return {"ok": True, "message": "```diff\n" + truncate("".join(diff), 4000) + "\n```"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur diff : {e}"}


class AgentDev(AgentBase):
    """Développement : git, pip/npm, run_python, scripts."""
    name = "AgentDev"

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k == "run_python":       return self._run_python(p)
        if k == "run_script":       return self._run_script(p)
        if k in ("git", "git_status", "git_commit", "git_push", "git_pull"):
            return self._git(p)
        if k == "install_package":   return self._install_package(p)
        if k == "uninstall_package": return self._uninstall_package(p)
        if k == "list_packages":     return self._list_packages(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentDev : {k}"}

    def _run_python(self, p: "ActionProposal") -> Dict:
        code = (p.command or p.meta.get("code", "")).strip()
        if not code:
            return {"ok": False, "message": "Code Python vide."}
        # Exécute dans un sous-process Python
        script = SCRIPTS_DIR / f"tmp_{uuid.uuid4().hex[:8]}.py"
        try:
            script.write_text(code, encoding="utf-8")
            result = subprocess.run(
                [sys.executable, str(script)],
                capture_output=True, text=True, timeout=30,
                encoding="utf-8", errors="replace"
            )
            out = (result.stdout or "") + (result.stderr or "")
            ok  = result.returncode == 0
            return {
                "ok": ok,
                "message": f"{'✅' if ok else '⚠️'} Python :\n```\n{truncate(out, 3000)}\n```"
            }
        except Exception as e:
            return {"ok": False, "message": f"Erreur run_python : {e}"}
        finally:
            try: script.unlink()
            except Exception: pass

    def _run_script(self, p: "ActionProposal") -> Dict:
        path = Path(p.target.strip())
        if not path.exists():
            return {"ok": False, "message": f"Script introuvable : {path}"}
        ext = path.suffix.lower()
        if ext == ".py":
            cmd = f'"{sys.executable}" "{path}"'
        elif ext in (".sh",):
            cmd = f'bash "{path}"'
        elif ext in (".bat", ".cmd"):
            cmd = f'"{path}"'
        elif ext == ".ps1":
            cmd = f'powershell -File "{path}"'
        else:
            cmd = f'"{path}"'
        return self._shell.run(cmd)

    def _git(self, p: "ActionProposal") -> Dict:
        k   = p.kind
        cmd = (p.command or "").strip()
        cwd = p.meta.get("cwd") or str(PROJECT_ROOT)
        if not cmd:
            if k == "git_status":  cmd = "git status"
            elif k == "git_push":  cmd = "git push"
            elif k == "git_pull":  cmd = "git pull"
            elif k == "git_commit":
                msg = p.meta.get("message", "update")
                cmd = f'git add -A && git commit -m "{msg}"'
            else:
                cmd = f"git {p.target or 'status'}"
        return self._shell.run(cmd, cwd=cwd)

    def _install_package(self, p: "ActionProposal") -> Dict:
        target = (p.target or "").strip()
        # Format: "pip:requests" ou "npm:lodash" ou juste "requests"
        if ":" in target:
            manager, pkg = target.split(":", 1)
        else:
            manager, pkg = "pip", target
        manager = manager.lower().strip()
        pkg     = pkg.strip()
        if not pkg:
            return {"ok": False, "message": "Nom du package manquant."}
        if manager == "pip":
            cmd = f'"{sys.executable}" -m pip install {pkg}'
        elif manager == "npm":
            cmd = f"npm install -g {pkg}"
        elif manager in ("choco", "chocolatey"):
            cmd = f"choco install {pkg} -y"
        elif manager == "winget":
            cmd = f"winget install {pkg}"
        else:
            cmd = f'"{sys.executable}" -m pip install {pkg}'
        result = self._shell.run(cmd)
        if result["ok"]:
            self._db.packages_update([{"name": pkg, "version": "", "manager": manager}])
        return result

    def _uninstall_package(self, p: "ActionProposal") -> Dict:
        target = (p.target or "").strip()
        if ":" in target:
            manager, pkg = target.split(":", 1)
        else:
            manager, pkg = "pip", target
        if manager == "pip":
            cmd = f'"{sys.executable}" -m pip uninstall -y {pkg}'
        elif manager == "npm":
            cmd = f"npm uninstall -g {pkg}"
        else:
            cmd = f'"{sys.executable}" -m pip uninstall -y {pkg}'
        return self._shell.run(cmd)

    def _list_packages(self, p: "ActionProposal") -> Dict:
        manager = (p.target or p.meta.get("manager", "")).strip().lower() or None
        pkgs    = self._db.packages_list(manager)
        if not pkgs:
            return {"ok": True, "message": "Aucun package trouvé dans la base. Lancez un scan PC."}
        lines = [f"📦 Packages ({manager or 'tous'}) — {len(pkgs)} entrées :"]
        for pkg in pkgs[:50]:
