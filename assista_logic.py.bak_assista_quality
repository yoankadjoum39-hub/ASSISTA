class AgentReseau(AgentBase):
    """Réseau : scan, ping, info, ports."""
    name = "AgentReseau"

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k == "network_info":  return self._network_info(p)
        if k == "ping_host":     return self._ping(p)
        if k == "network_scan":  return self._network_scan(p)
        if k == "port_scan":     return self._port_scan(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentReseau : {k}"}

    def _network_info(self, p: "ActionProposal") -> Dict:
        lines = ["🌐 **Informations réseau :**\n"]
        # IP locale
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
            lines.append(f"• IP locale : `{local_ip}`")
        except Exception:
            lines.append("• IP locale : non disponible")
        # Hostname
        lines.append(f"• Hostname : `{socket.gethostname()}`")
        # Interfaces
        if psutil:
            try:
                addrs = psutil.net_if_addrs()
                for iface, addr_list in addrs.items():
                    for addr in addr_list:
                        if addr.family == socket.AF_INET:
                            lines.append(f"• {iface} : `{addr.address}`")
            except Exception:
                pass
        return {"ok": True, "message": "\n".join(lines)}

    def _ping(self, p: "ActionProposal") -> Dict:
        host = (p.target or "8.8.8.8").strip()
        try:
            start = time.time()
            socket.setdefaulttimeout(3)
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.connect((host, 80))
            ms = (time.time() - start) * 1000
            self._db.netscan_add(host, 80, "open", ms)
            return {"ok": True, "message": f"🏓 Ping `{host}` : {ms:.1f} ms (port 80 ouvert)"}
        except Exception:
            # ICMP fallback
            cmd = (f"ping -n 1 -w 1000 {host}" if platform.system() == "Windows"
                   else f"ping -c 1 -W 1 {host}")
            result = self._shell.run(cmd)
            self._db.netscan_add(host, None, "ping", None)
            return result

    def _network_scan(self, p: "ActionProposal") -> Dict:
        """Scan du réseau local (plage /24)."""
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
            base = ".".join(local_ip.split(".")[:3])
        except Exception:
            return {"ok": False, "message": "Impossible de déterminer le réseau local."}

        found  = []
        lock   = threading.Lock()

        def probe(i):
            host = f"{base}.{i}"
            try:
                socket.setdefaulttimeout(0.5)
                with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                    s.connect((host, 80))
                with lock:
                    found.append(host)
                self._db.netscan_add(host, 80, "open", None)
            except Exception:
                pass

        threads = [threading.Thread(target=probe, args=(i,), daemon=True) for i in range(1, 255)]
        for t in threads: t.start()
        for t in threads: t.join(timeout=2)

        if not found:
            return {"ok": True, "message": f"🔍 Scan {base}.1-254 : aucun hôte actif trouvé."}
        lines = [f"🔍 Hôtes actifs sur {base}.0/24 ({len(found)}) :"]
        for h in sorted(found):
            lines.append(f"  • {h}")
        return {"ok": True, "message": "\n".join(lines)}

    def _port_scan(self, p: "ActionProposal") -> Dict:
        host  = (p.target or "localhost").strip()
        ports = p.meta.get("ports", [21, 22, 23, 25, 53, 80, 110, 143, 443, 3306, 5432, 8080, 8443, 3389])
        open_ports = []
        for port in ports:
            try:
                socket.setdefaulttimeout(0.5)
                with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                    s.connect((host, int(port)))
                open_ports.append(port)
                self._db.netscan_add(host, port, "open", None)
            except Exception:
                self._db.netscan_add(host, port, "closed", None)
        if not open_ports:
            return {"ok": True, "message": f"🔒 Aucun port ouvert sur `{host}` parmi {ports}"}
        lines = [f"🔓 Ports ouverts sur `{host}` :"]
        for port in open_ports:
            lines.append(f"  • Port {port}")
        return {"ok": True, "message": "\n".join(lines)}


class AgentSysteme(AgentBase):
    """Système : infos, processus, env."""
    name = "AgentSysteme"

    def execute(self, p: "ActionProposal") -> Dict:
        k = p.kind
        if k == "system_info":    return self._system_info(p)
        if k == "list_processes": return self._list_processes(p)
        if k == "kill_process":   return self._kill_process(p)
        if k == "env_get":        return self._env_get(p)
        if k == "env_set":        return self._env_set(p)
        if k == "context":        return self._context(p)
        return {"ok": False, "message": f"Kind inconnu pour AgentSysteme : {k}"}

    def _system_info(self, p: "ActionProposal") -> Dict:
        lines = ["🖥️ **Informations système :**\n"]
        lines.append(f"• OS : {platform.system()} {platform.version()}")
        lines.append(f"• Machine : {platform.machine()} — {platform.processor()}")
        if psutil:
            try:
                cpu_pct  = psutil.cpu_percent(interval=0.5)
                ram      = psutil.virtual_memory()
                disk     = psutil.disk_usage("/")
                lines.append(f"• CPU : {cpu_pct}% ({psutil.cpu_count()} cœurs)")
                lines.append(f"• RAM : {human_size(ram.used)} / {human_size(ram.total)} ({ram.percent}%)")
                lines.append(f"• Disque : {human_size(disk.used)} / {human_size(disk.total)} ({disk.percent}%)")
                boot = datetime.fromtimestamp(psutil.boot_time()).strftime("%Y-%m-%d %H:%M")
                lines.append(f"• Démarré : {boot}")
            except Exception as e:
                lines.append(f"• psutil error : {e}")
        else:
            cmd = (
                "Get-CimInstance Win32_OperatingSystem | Select-Object Caption,FreePhysicalMemory,TotalVisibleMemorySize | Out-String; "
                "Get-PSDrive C | Select-Object Used,Free | Out-String"
                if platform.system() == "Windows"
                else "uname -a; free -h; df -h /"
            )
            return self._shell.run(cmd)
        return {"ok": True, "message": "\n".join(lines)}

    def _list_processes(self, p: "ActionProposal") -> Dict:
        if psutil:
            try:
                procs = []
                for proc in psutil.process_iter(["pid", "name", "cpu_percent", "memory_info"]):
                    try:
                        procs.append(proc.info)
                    except Exception:
                        pass
                procs.sort(key=lambda x: x.get("cpu_percent") or 0, reverse=True)
                lines = ["⚙️ **Top 20 processus (CPU) :**\n"]
                for pr in procs[:20]:
                    mem = human_size(pr.get("memory_info") and pr["memory_info"].rss or 0)
                    lines.append(f"  [{pr['pid']:5}] {(pr['name'] or '?')[:30]:30} CPU:{pr.get('cpu_percent',0):.1f}% MEM:{mem}")
                return {"ok": True, "message": "\n".join(lines)}
            except Exception:
                pass
        cmd = ("Get-Process | Sort-Object CPU -Descending | Select-Object -First 20 Name,Id,CPU,WorkingSet | Format-Table -AutoSize | Out-String"
               if platform.system() == "Windows" else "ps aux --sort=-%cpu | head -22")
        return self._shell.run(cmd)

    def _kill_process(self, p: "ActionProposal") -> Dict:
        name = (p.target or p.meta.get("name", "")).strip()
        if not name:
            return {"ok": False, "message": "Nom de processus manquant."}
        if psutil:
            killed = []
            for proc in psutil.process_iter(["pid", "name"]):
                try:
                    if normalize_text(name) in normalize_text(proc.info.get("name") or ""):
                        proc.kill()
                        killed.append(str(proc.info["pid"]))
                except Exception:
                    pass
            if killed:
                return {"ok": True, "message": f"✅ Processus tués : {', '.join(killed)}"}
        cmd = (f"Stop-Process -Name '{name}' -Force"
               if platform.system() == "Windows" else f"pkill -f '{name}'")
        return self._shell.run(cmd)

    def _env_get(self, p: "ActionProposal") -> Dict:
        key = (p.target or "").strip()
        if key:
            val = os.environ.get(key, "")
            return {"ok": True, "message": f"🔑 {key} = `{val}`" if val else f"Variable `{key}` non définie."}
        # Liste toutes les variables
        lines = ["🔑 **Variables d'environnement :**\n"]
        for k, v in sorted(os.environ.items())[:50]:
            lines.append(f"  {k} = {truncate(v, 80)}")
        return {"ok": True, "message": "\n".join(lines)}

    def _env_set(self, p: "ActionProposal") -> Dict:
        key = (p.target or "").strip()
        val = str(p.meta.get("value", "")).strip()
        if not key:
            return {"ok": False, "message": "Clé de variable manquante."}
        os.environ[key] = val
        return {"ok": True, "message": f"✅ {key} = `{val}` (session courante)"}

    def _context(self, p: "ActionProposal") -> Dict:
        snap = self._ctx.snapshot()
        return {"ok": True, "message": json.dumps(snap, ensure_ascii=False, indent=2)}


