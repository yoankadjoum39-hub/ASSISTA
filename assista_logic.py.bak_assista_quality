#  POLITIQUE DE SÉCURITÉ v2
# ══════════════════════════════════════════════════════════════════════════════
class AssistaPermissionPolicyV2:
    SAFE_KINDS = {
        "context", "capture_screen", "analyze_screen", "take_screenshot",
        "list_dir", "search_files", "search_file_content", "read_file",
        "open_url", "open_path", "open_app", "speak_text", "play_media",
        "list_processes", "system_info", "network_info", "ping_host",
        "clipboard_read", "clipboard_write", "notify", "notify_toast",
        "git_status", "list_packages", "db_query", "db_pcmap_search", "db_stats",
        "env_get", "hash_file", "diff_files", "audit_log",
        "schedule", "schedule_list", "schedule_cancel",
        "routine_list", "port_scan", "security_scan",
    }
    MODERATE_KINDS = {
        "create_text_file", "write_file", "copy_file", "move_file",
        "zip_files", "extract_zip",
        "git", "git_commit", "git_push", "git_pull",
        "install_package", "uninstall_package",
        "run_python", "run_script",
        "clipboard_write", "env_set",
        "routine_add", "routine_delete",
    }
    DANGEROUS_KINDS = {
        "delete_file", "kill_process",
        "network_scan", "run_shell",
    }

    def __init__(self) -> None:
        pass

    def review(self, proposal: "ActionProposal", autopilot: bool = False,
               shell: Optional[AssistaShell] = None) -> "ActionProposal":
        kind = proposal.kind

        if kind in self.SAFE_KINDS:
            proposal.risk = "safe"
            proposal.requires_confirm = proposal.requires_approval = False
            return proposal

        if kind == "run_shell" and shell:
            classification = shell.classify(proposal.command or proposal.target)
            if not classification["allowed"]:
                proposal.risk = "blocked"
                proposal.requires_confirm = proposal.requires_approval = True
                proposal.summary = f"🚫 BLOQUÉ : {classification['reason']}"
                return proposal
            risk = classification["risk"]
            proposal.risk = risk
            if risk == "dangerous":
                proposal.requires_confirm = proposal.requires_approval = True
            elif risk == "moderate":
                proposal.requires_confirm = proposal.requires_approval = not autopilot
            else:
                proposal.requires_confirm = proposal.requires_approval = False
            return proposal

        if kind in self.MODERATE_KINDS:
            proposal.risk = "moderate"
            proposal.requires_confirm = proposal.requires_approval = not autopilot
            return proposal

        if kind in self.DANGEROUS_KINDS:
            proposal.risk = "dangerous"
            proposal.requires_confirm = proposal.requires_approval = True
            return proposal

        # Fallback
        proposal.risk = "moderate"
        proposal.requires_confirm = proposal.requires_approval = not autopilot
        return proposal

