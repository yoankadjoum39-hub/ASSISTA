            "auto":      AgentAutomatisation(shell, db, ctx),
            "web":       AgentWeb(shell, db, ctx),
            "clipboard": AgentClipboard(shell, db, ctx),
            "notifs":    AgentNotifications(shell, db, ctx),
            "planif":    AgentPlanificateur(shell, db, ctx, brain_ref),
            "secu":      AgentSecurite(shell, db, ctx),
        }
        # Actions directes (hors agents)
        self._direct = {
            "run_shell":       self._exec_shell,
            "open_app":        self._exec_open_app,
            "open_path":       self._exec_open_path,
            "play_media":      self._exec_play_media,
            "capture_screen":  self._exec_capture_screen,
            "take_screenshot": self._exec_capture_screen,
            "analyze_screen":  self._exec_analyze_screen,
            "speak_text":      self._exec_speak_text,
            # DB internals
            "db_query":        self._exec_db_query,
            "db_pcmap_search": self._exec_db_pcmap_search,
            "db_stats":        self._exec_db_stats,
        }

    def execute(self, proposal: "ActionProposal") -> Dict:
        # Direct d'abord
        handler = self._direct.get(proposal.kind)
        if handler:
            try:
                return handler(proposal)
            except Exception as e:
                return {"ok": False, "message": f"Erreur direct {proposal.kind} : {e}"}
        # Puis agents
        agent_key = self.AGENT_MAP.get(proposal.kind)
        if agent_key:
            agent = self._agents.get(agent_key)
            if agent:
                try:
                    return agent.execute(proposal)
                except Exception as e:
                    return {"ok": False, "message": f"Erreur agent {agent.name} ({proposal.kind}) : {e}"}
        return {"ok": False, "message": f"Action inconnue : {proposal.kind}"}

    def get_agent(self, name: str) -> Optional[AgentBase]:
        return self._agents.get(name)

    # ── Actions directes ──────────────────────────────────────────────────────
    def _exec_shell(self, p: "ActionProposal") -> Dict:
        cmd = (p.command or p.target).strip()
        if not cmd:
            return {"ok": False, "message": "Commande vide."}
        return self._shell.run(cmd)

    def _exec_open_app(self, p: "ActionProposal") -> Dict:
        name = p.target.strip()
        exe  = APP_ALIASES.get(normalize_text(name), name)
        try:
            if exe.startswith("ms-"):
                os.startfile(exe)
            elif platform.system() == "Windows":
                subprocess.Popen(
                    exe, shell=True,
                    creationflags=subprocess.DETACHED_PROCESS | subprocess.CREATE_NEW_PROCESS_GROUP,
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, stdin=subprocess.DEVNULL
                )
            else:
                subprocess.Popen(exe, shell=True,
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                                 stdin=subprocess.DEVNULL)
            return {"ok": True, "message": f"🚀 Lancement de {name}"}
        except Exception as e:
            return {"ok": False, "message": f"Échec lancement {name} : {e}"}

    def _exec_open_path(self, p: "ActionProposal") -> Dict:
        path = Path(p.target.strip())
        if not path.exists():
            return {"ok": False, "message": f"Chemin introuvable : {path}"}
        try:
            if platform.system() == "Windows":
                os.startfile(str(path))
            elif platform.system() == "Darwin":
                subprocess.Popen(["open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return {"ok": True, "message": f"📂 Ouverture de {path}"}
        except Exception as e:
            return {"ok": False, "message": f"Erreur : {e}"}

    def _exec_play_media(self, p: "ActionProposal") -> Dict:
        AUDIO_EXTS = {".mp3", ".flac", ".ogg", ".wav", ".aac", ".m4a", ".wma", ".opus"}
        VIDEO_EXTS = {".mp4", ".mkv", ".avi", ".mov", ".wmv", ".webm"}
        MEDIA_EXTS = AUDIO_EXTS | VIDEO_EXTS
        target = (p.target or p.command or "").strip().strip('"\'')
        home   = Path.home()
        music_aliases = {"musique", "music", "mes musiques", "dossier musique"}
        if not target or target.lower() in music_aliases:
            candidates = [home/"Music", home/"Musique", home/"Documents"/"Music"]
            music_dir  = next((d for d in candidates if d.exists()), None)
            if not music_dir:
                return {"ok": False, "message": "❌ Dossier Musique introuvable."}
            target = str(music_dir)
        path = Path(target)
        if path.is_dir():
            found = []
            for ext in AUDIO_EXTS:
                found.extend(path.glob(f"*{ext}"))
                found.extend(path.glob(f"**/*{ext}"))
                if found:
                    break
            if not found:
                return {"ok": False, "message": f"❌ Aucun fichier audio dans {path}"}
            path = found[0]
        if not path.exists():
            return {"ok": False, "message": f"❌ Fichier introuvable : {path}"}
        if path.suffix.lower() not in MEDIA_EXTS:
            return {"ok": False, "message": f"❌ Format non supporté : {path.suffix}"}
        try:
            if platform.system() == "Windows":
                os.startfile(str(path))
            elif platform.system() == "Darwin":
                subprocess.Popen(["open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            else:
                subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return {"ok": True, "message": f"🎵 Lecture : {path.name}"}
        except Exception as e:
            return {"ok": False, "message": f"❌ {e}"}

    def _exec_capture_screen(self, p: "ActionProposal") -> Dict:
        return self._ctx.capture_screen()

    def _exec_analyze_screen(self, p: "ActionProposal") -> Dict:
        return self._ctx.analyze_screen()

    def _exec_speak_text(self, p: "ActionProposal") -> Dict:
        text = (p.command or p.target or p.summary).strip()
        return {"ok": True, "message": f"🔊 {text}", "_speak": text}

    def _exec_db_query(self, p: "ActionProposal") -> Dict:
        sql = (p.command or p.meta.get("sql", "")).strip()
        if not sql:
            return {"ok": False, "message": "Requête SQL manquante."}
        # Whitelist : seulement SELECT
        if not re.match(r"^\s*SELECT\b", sql, re.IGNORECASE):
            return {"ok": False, "message": "Seules les requêtes SELECT sont autorisées via db_query."}
        try:
            rows = self._db.raw_query(sql)
            if not rows:
                return {"ok": True, "message": "Aucun résultat."}
            lines = [f"📊 {len(rows)} résultat(s) :"]
            for r in rows[:30]:
                lines.append("  " + json.dumps(r, ensure_ascii=False))
            return {"ok": True, "message": "\n".join(lines)}
        except Exception as e:
            return {"ok": False, "message": f"Erreur SQL : {e}"}

    def _exec_db_pcmap_search(self, p: "ActionProposal") -> Dict:
        query = (p.target or p.meta.get("query", "")).strip()
        if not query:
            return {"ok": False, "message": "Terme de recherche manquant."}
        results = self._db.pcmap_search(query)
        if not results:
            return {"ok": True, "message": f"Aucun fichier trouvé pour '{query}' dans la cartographie PC."}
        lines = [f"🗺️ Cartographie PC — '{query}' ({len(results)} résultats) :"]
        for r in results:
            icon = "📁" if r["type"] == "dir" else "📄"
            lines.append(f"  {icon} {r['path']}")
        return {"ok": True, "message": "\n".join(lines)}

    def _exec_db_stats(self, p: "ActionProposal") -> Dict:
        stats = self._db.pcmap_stats()
        facts_count  = len(self._db.fact_list(9999))
        audit_count  = len(self._db.audit_get(9999))
        notif_count  = len(self._db.notif_list(9999))
        task_count   = len(self._db.task_list())
        lines = ["📊 **Statistiques ASSISTA DB :**\n"]
        lines.append(f"• PC Map : {stats['total']} entrées ({stats['files']} fichiers, {stats['dirs']} dossiers)")
        lines.append(f"• Mémoire : {facts_count} faits mémorisés")
        lines.append(f"• Shell audit : {audit_count} commandes")
        lines.append(f"• Notifications : {notif_count}")
        lines.append(f"• Tâches planifiées : {task_count}")
        if stats["top_extensions"]:
            lines.append("\n• Extensions les plus fréquentes :")
            for e in stats["top_extensions"]:
                lines.append(f"  {e['ext'] or '(sans ext)'} : {e['cnt']}")
        return {"ok": True, "message": "\n".join(lines)}

